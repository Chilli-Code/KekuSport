---
import Layout from "../../layouts/Layout.astro";
---

<Layout>

  <!-- ════════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <section class="relative flex min-h-svh w-full items-center justify-center overflow-hidden">

    <!-- Fondo imagen -->
    <div class="hero-bg-img absolute inset-0 w-full bg-[url('/images/hero_Landing.webp')] bg-cover bg-center"></div>

    <!-- Glows espaciales -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="hero-glow-top absolute -top-20 left-1/2 -translate-x-1/2 w-[60%] h-[50%] rounded-full blur-[80px] opacity-30" style="background:radial-gradient(ellipse,#00ff88,transparent 70%)"></div>
      <div class="absolute top-0 left-0 w-[40%] h-[70%] rounded-full blur-[100px] opacity-20" style="background:radial-gradient(ellipse,#00ff88,transparent 70%)"></div>
      <div class="absolute top-0 right-0 w-[40%] h-[70%] rounded-full blur-[100px] opacity-15" style="background:radial-gradient(ellipse,#7c3aed,transparent 70%)"></div>
    </div>

    <!-- Stars overlay -->
    <div class="hero-stars absolute inset-0 pointer-events-none opacity-50"></div>

    <!-- Arco de campo decorativo -->
    <div class="absolute bottom-[-6vw] left-1/2 -translate-x-1/2 w-[55vw] h-[14vw] rounded-[50%_50%_0_0/100%_100%_0_0] border border-[rgba(0,255,136,.1)] pointer-events-none"></div>

    <!-- Contenido -->
    <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center px-4 py-32 text-center">

      <!-- Badge -->
      <span class="animate-fade-in mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-theme-gold)]/40 bg-[var(--color-theme-gold)]/5 px-5 py-1.5 text-[0.6rem] font-bold tracking-[0.25em] text-[var(--color-theme-gold)] backdrop-blur-sm">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-[#00ff88] animate-pulse"></span>
        PLATAFORMA DEPORTIVA
      </span>

      <!-- Título -->
      <h1 class="animate-fade-in hero-title font-cinzel text-5xl font-black uppercase leading-[0.95] tracking-tight text-white md:text-7xl lg:text-8xl">
        CREA TU<br />
        <span class="hero-gold-text">TORNEO</span>
      </h1>

      <!-- Descripción -->
      <p class="animate-fade-in mt-6 max-w-xl text-sm leading-relaxed text-white/55 md:text-base" style="animation-delay:.2s">
        Organiza torneos de fútbol <strong class="font-bold text-white/90">presenciales</strong> y 
        <strong class="font-bold text-white/90">virtuales</strong>. Gestiona equipos, sigue 
        estadísticas en vivo y activa apuestas entre participantes.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap justify-center gap-4" style="animation-delay:.4s">
        <a href="#crear" class="cta-primary">
          CREAR TORNEO GRATIS
        </a>
        <a href="#como-funciona" class="cta-ghost">
          CÓMO FUNCIONA
        </a>
      </div>

      <!-- Stats rápidas -->
      <div class="mt-16 grid grid-cols-2 gap-x-8 gap-y-6 md:grid-cols-4" style="animation-delay:.6s">
        {[
          { num: '10+',  label: 'Modalidades'      },
          { num: '500+', label: 'Torneos creados'  },
          { num: '12K+', label: 'Jugadores'        },
          { num: '98%',  label: 'Satisfacción'     },
        ].map(s => (
          <div class="flex flex-col items-center gap-1">
            <span class="font-cinzel text-3xl font-black text-[var(--color-theme-gold)]">{s.num}</span>
            <span class="text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-white/35">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Degradado inferior -->
    <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background:linear-gradient(to top,var(--color-theme-midnight),transparent)"></div>
  </section>

  <!-- ════════════════════════════════════════
       MODALIDADES
  ════════════════════════════════════════ -->
  <section id="crear" class="relative px-4 py-28 overflow-hidden">

    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[50%] h-[1px]" style="background:linear-gradient(to right,transparent,rgba(0,255,136,.3),transparent)"></div>
    </div>

    <div class="mx-auto max-w-6xl">

      <!-- Cabecera sección -->
      <div class="mb-16 text-center">
        <div class="section-label">MODALIDADES</div>
        <h2 class="section-title">PRESENCIAL O VIRTUAL</h2>
        <p class="section-desc">
          Elige el formato que mejor se adapte a tu liga. Ambas modalidades incluyen 
          estadísticas, apuestas y soporte completo.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">

        <!-- Card Presencial -->
        <div class="feature-card group">
          <div class="feature-card-glow" style="background:radial-gradient(ellipse at 30% 30%,rgba(0,255,136,.07),transparent 65%)"></div>
          <!-- Esquinas HUD -->
          <span class="hud-corner hud-corner--tl"></span>
          <span class="hud-corner hud-corner--tr"></span>
          <span class="hud-corner hud-corner--bl"></span>
          <span class="hud-corner hud-corner--br"></span>

          <div class="relative z-10">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl border border-[#00ff88]/20 bg-[#00ff88]/10 text-2xl">🏟️</div>
            <h3 class="mb-1 font-cinzel text-xl font-black uppercase tracking-wide text-white">Torneo Presencial</h3>
            <p class="mb-5 text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-[#00ff88]/70">Para ligas en cancha real</p>
            <ul class="space-y-3">
              {['Gestión de sedes y horarios','Árbitros y reglamento oficial','Estadísticas en tiempo real','Apuestas entre equipos presentes'].map(item => (
                <li class="flex items-start gap-2.5 text-sm text-white/55">
                  <span class="mt-0.5 shrink-0 text-[#00ff88]">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-8">
              <a href="#" class="cta-ghost-sm" style="border-color:rgba(0,255,136,.35);color:rgba(0,255,136,.85)">
                Crear presencial →
              </a>
            </div>
          </div>
        </div>

        <!-- Card Virtual -->
        <div class="feature-card group">
          <div class="feature-card-glow" style="background:radial-gradient(ellipse at 70% 30%,rgba(124,58,237,.07),transparent 65%)"></div>
          <span class="hud-corner hud-corner--tl"></span>
          <span class="hud-corner hud-corner--tr"></span>
          <span class="hud-corner hud-corner--bl"></span>
          <span class="hud-corner hud-corner--br"></span>

          <div class="relative z-10">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl border border-purple-500/20 bg-purple-500/10 text-2xl">🖥️</div>
            <h3 class="mb-1 font-cinzel text-xl font-black uppercase tracking-wide text-white">Torneo Virtual</h3>
            <p class="mb-5 text-[0.6rem] font-semibold uppercase tracking-[0.2em] text-purple-400/70">Para consola y PC</p>
            <ul class="space-y-3">
              {['Partidos online multiplataforma','Salas privadas y públicas','Streaming y retransmisión','Sistema de fair play'].map(item => (
                <li class="flex items-start gap-2.5 text-sm text-white/55">
                  <span class="mt-0.5 shrink-0 text-purple-400">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-8">
              <a href="#" class="cta-ghost-sm" style="border-color:rgba(168,85,247,.35);color:rgba(168,85,247,.85)">
                Crear virtual →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       APUESTAS
  ════════════════════════════════════════ -->
  <section id="apuestas" class="relative px-4 py-28 overflow-hidden">

    <!-- Separador top -->
    <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(to right,transparent,rgba(0,255,136,.2),transparent)"></div>

    <!-- Glow fondo -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[60%] h-[40%] blur-[100px] opacity-15" style="background:radial-gradient(ellipse,var(--color-theme-gold),transparent 70%)"></div>
    </div>

    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <div class="section-label">APUESTAS</div>
        <h2 class="section-title">APUESTA ENTRE EQUIPOS</h2>
        <p class="section-desc">
          Activa el módulo de apuestas para que los equipos compitan también fuera de la cancha.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-3">
        {[
          { icon: '💰', title: 'Apuesta Directa',  color: '#00ff88', desc: 'Los equipos apuestan directamente entre sí. El ganador se lleva el pozo completo.' },
          { icon: '📊', title: 'Cuotas en Vivo',   color: '#fbbf24', desc: 'Las cuotas se actualizan en tiempo real según el rendimiento de cada equipo.' },
          { icon: '🏆', title: 'Torneo Entero',     color: '#a78bfa', desc: 'Apuesta por el campeón desde el día uno y acumula ganancias a lo largo del torneo.' },
        ].map(card => (
          <div class="group relative rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7 text-center transition-all duration-300 hover:border-[var(--color-theme-gold)]/30 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(199,168,107,.08)] overflow-hidden">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`background:radial-gradient(ellipse at 50% 0%,${card.color}0a,transparent 65%)`}></div>
            <div class="relative z-10">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full text-2xl" style={`background:${card.color}12;border:1px solid ${card.color}30`}>
                {card.icon}
              </div>
              <h4 class="mb-2 font-cinzel text-sm font-black uppercase tracking-wider text-white">{card.title}</h4>
              <p class="text-[0.62rem] leading-relaxed text-white/40">{card.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       ESTADÍSTICAS EN TIEMPO REAL
  ════════════════════════════════════════ -->
  <section class="relative px-4 py-28 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(to right,transparent,rgba(0,255,136,.2),transparent)"></div>

    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <div class="section-label">ESTADÍSTICAS</div>
        <h2 class="section-title">DATOS EN TIEMPO REAL</h2>
        <p class="section-desc">
          Cada partido, cada jugador, cada torneo. Toda la información que necesitas en un solo lugar.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">

        {[
          {
            icon: '⚽', iconBg: 'rgba(0,255,136,.1)', iconBorder: 'rgba(0,255,136,.2)',
            title: 'Partidos',
            rows: [
              ['Posesión',           '64% - 36%'],
              ['Remates',            '12 - 5'   ],
              ['Pases completados',  '342 - 198' ],
              ['Faltas',             '8 - 14'    ],
              ['Tarjetas',           '1 - 3'     ],
            ],
          },
          {
            icon: '👤', iconBg: 'rgba(251,191,36,.08)', iconBorder: 'rgba(251,191,36,.2)',
            title: 'Jugadores',
            rows: [
              ['Goles',           '7'    ],
              ['Asistencias',     '4'    ],
              ['Min. jugados',    "540'" ],
              ['Efectividad',     '83%'  ],
              ['Valoración',      '8.4'  ],
            ],
          },
          {
            icon: '🏆', iconBg: 'rgba(168,85,247,.1)', iconBorder: 'rgba(168,85,247,.2)',
            title: 'Torneo',
            rows: [
              ['Equipos',        '16'     ],
              ['Partidos',       '48'     ],
              ['Goles totales',  '142'    ],
              ['Media goles',    '2.96'   ],
              ['Jornada',        '6 / 14' ],
            ],
          },
        ].map(card => (
          <div class="group relative rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7 transition-all duration-300 hover:border-[var(--color-theme-gold)]/25 hover:-translate-y-1 overflow-hidden">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`background:radial-gradient(ellipse at 50% 0%,${card.iconBg},transparent 60%)`}></div>
            <div class="relative z-10">
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl text-lg" style={`background:${card.iconBg};border:1px solid ${card.iconBorder}`}>
                {card.icon}
              </div>
              <h3 class="mb-5 font-cinzel text-base font-black uppercase tracking-wider text-white">{card.title}</h3>
              <ul class="space-y-2.5">
                {card.rows.map(([label, val]) => (
                  <li class="flex justify-between items-center gap-2">
                    <span class="text-[0.62rem] font-medium uppercase tracking-wide text-white/40">{label}</span>
                    <span class="font-cinzel text-xs font-bold text-white/80">{val}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       CÓMO FUNCIONA
  ════════════════════════════════════════ -->
  <section id="como-funciona" class="relative px-4 py-28 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(to right,transparent,rgba(0,255,136,.2),transparent)"></div>

    <div class="mx-auto max-w-5xl">
      <div class="mb-16 text-center">
        <div class="section-label">GUÍA</div>
        <h2 class="section-title">CÓMO FUNCIONA</h2>
      </div>

      <div class="relative grid gap-0 md:grid-cols-4">
        <!-- Línea conectora desktop -->
        <div class="absolute top-6 left-[12%] right-[12%] h-px hidden md:block" style="background:linear-gradient(to right,rgba(0,255,136,.15),rgba(199,168,107,.3),rgba(0,255,136,.15))"></div>

        {[
          { n:'1', title:'Regístrate',     desc:'Crea tu cuenta gratuita en menos de 2 minutos sin tarjeta.' },
          { n:'2', title:'Crea Torneo',    desc:'Elige modalidad, número de equipos y reglas del torneo.'    },
          { n:'3', title:'Invita Equipos', desc:'Comparte el código y los equipos se unen automáticamente.' },
          { n:'4', title:'A Jugar',        desc:'Sigue estadísticas, apuestas y resultados en vivo.'         },
        ].map((step, i) => (
          <div class="relative flex flex-col items-center gap-4 p-6 text-center">
            <div
              class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full font-cinzel text-base font-black transition-all duration-300"
              style={`background:color-mix(in srgb,var(--color-theme-gold) 12%,transparent);border:1px solid color-mix(in srgb,var(--color-theme-gold) 30%,transparent);color:var(--color-theme-gold)`}
            >
              {step.n}
            </div>
            <div>
              <h4 class="mb-1.5 font-cinzel text-sm font-black uppercase tracking-wider text-white">{step.title}</h4>
              <p class="text-[0.6rem] leading-relaxed text-white/40">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       CTA FINAL
  ════════════════════════════════════════ -->
  <section class="relative px-4 py-32 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(to right,transparent,rgba(0,255,136,.25),transparent)"></div>

    <!-- Glow central -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[55%] h-[55%] blur-[90px] opacity-20" style="background:radial-gradient(ellipse,#00ff88,transparent 70%)"></div>
    </div>

    <!-- Estrellas -->
    <div class="hero-stars absolute inset-0 pointer-events-none opacity-30"></div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <div class="section-label mb-4">EMPIEZA HOY</div>
      <h2 class="font-cinzel text-3xl font-black uppercase leading-tight text-white md:text-6xl">
        ¿LISTO PARA CREAR<br/>
        <span class="hero-gold-text">TU TORNEO?</span>
      </h2>
      <p class="mx-auto mt-5 max-w-lg text-sm text-white/45">
        Únete a la comunidad de organizadores y lleva tu liga al siguiente nivel.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="#" class="cta-primary">
          CREAR TORNEO AHORA
        </a>
        <a href="#" class="cta-ghost">
          VER DEMO
        </a>
      </div>

      <!-- Garantía -->
      <p class="mt-8 text-[0.55rem] font-medium uppercase tracking-[0.2em] text-white/25">
        ✓ Gratis para empezar &nbsp;·&nbsp; ✓ Sin tarjeta de crédito &nbsp;·&nbsp; ✓ Cancela cuando quieras
      </p>
    </div>
  </section>

</Layout>

<style>
  /* ─── Fondo estrellas ─── */
  .hero-stars {
    background-image:
      radial-gradient(1.5px 1.5px at 8%  15%, #fff, transparent),
      radial-gradient(1px   1px   at 25% 60%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 52% 12%, #a855f7, transparent),
      radial-gradient(1px   1px   at 70% 80%, #fff, transparent),
      radial-gradient(2px   2px   at 88% 38%, #00ff88, transparent),
      radial-gradient(1px   1px   at 18% 88%, #c084fc, transparent),
      radial-gradient(1.5px 1.5px at 62% 50%, #fff, transparent),
      radial-gradient(1px   1px   at 44% 32%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 94%  8%, #fff, transparent);
    background-size: 300px 300px;
    animation: twinkle 7s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0%{opacity:.25} 100%{opacity:.65} }

  /* ─── Hero título gradiente dorado ─── */
  .hero-gold-text {
    display: block;
    background: linear-gradient(135deg, #fef3c7 0%, var(--color-theme-gold) 40%, #a855f7 75%, #c084fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 30px rgba(199,168,107,.35));
  }

  /* ─── Glow animado top ─── */
  .hero-glow-top { animation: glowPulse 5s ease-in-out infinite alternate; }
  @keyframes glowPulse { 0%{opacity:.2;transform:translateX(-50%) scale(1)} 100%{opacity:.45;transform:translateX(-50%) scale(1.1)} }

  /* ─── Imagen hero ─── */
  .hero-bg-img {
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }

  /* ─── CTAs ─── */
  .cta-primary {
    display: inline-flex; align-items: center;
    padding: .75rem 2rem;
    border-radius: 10px;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: .65rem; font-weight: 800; letter-spacing: .2em;
    text-transform: uppercase; text-decoration: none;
    background: var(--color-theme-gold);
    color: var(--color-theme-midnight, #0a1024);
    transition: transform .2s, filter .2s, box-shadow .2s;
    box-shadow: 0 0 0 rgba(199,168,107,0);
  }
  .cta-primary:hover {
    transform: scale(1.04);
    filter: brightness(1.12);
    box-shadow: 0 0 28px rgba(199,168,107,.35);
  }

  .cta-ghost {
    display: inline-flex; align-items: center;
    padding: .75rem 2rem;
    border-radius: 10px;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: .65rem; font-weight: 800; letter-spacing: .2em;
    text-transform: uppercase; text-decoration: none;
    border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.75);
    background: transparent;
    transition: border-color .2s, color .2s, transform .2s;
  }
  .cta-ghost:hover {
    border-color: var(--color-theme-gold);
    color: var(--color-theme-gold);
    transform: translateY(-1px);
  }

  .cta-ghost-sm {
    display: inline-flex; align-items: center;
    padding: .45rem 1.1rem;
    border-radius: 99px;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: .55rem; font-weight: 700; letter-spacing: .15em;
    text-transform: uppercase; text-decoration: none;
    border: 1px solid;
    background: transparent;
    transition: background .2s, transform .15s;
  }
  .cta-ghost-sm:hover { background: rgba(255,255,255,.04); transform: translateY(-1px); }

  /* ─── Sección labels/títulos ─── */
  .section-label {
    display: inline-block;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: .55rem; font-weight: 700; letter-spacing: .3em;
    text-transform: uppercase;
    color: rgba(0,255,136,.7);
    margin-bottom: .6rem;
  }
  .section-title {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900; text-transform: uppercase;
    letter-spacing: .04em; line-height: 1.05;
    color: white;
  }
  .section-desc {
    margin: 1rem auto 0;
    max-width: 36rem;
    font-size: .8rem; line-height: 1.7;
    color: rgba(255,255,255,.4);
  }

  /* ─── Feature cards ─── */
  .feature-card {
    position: relative;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.025);
    padding: 2rem;
    overflow: hidden;
    transition: border-color .3s, transform .3s, box-shadow .3s;
  }
  .feature-card:hover {
    border-color: rgba(0,255,136,.25);
    transform: translateY(-4px);
    box-shadow: 0 0 40px rgba(0,255,136,.06), 0 8px 30px rgba(0,0,0,.3);
  }
  .feature-card-glow {
    position: absolute; inset: 0; pointer-events: none;
    transition: opacity .3s;
    opacity: 0;
  }
  .feature-card:hover .feature-card-glow { opacity: 1; }

  /* ─── Esquinas HUD ─── */
  .hud-corner {
    position: absolute;
    width: 12px; height: 12px;
    border-style: solid;
    border-color: rgba(0,255,136,.25);
    transition: border-color .3s, width .3s, height .3s;
    pointer-events: none;
  }
