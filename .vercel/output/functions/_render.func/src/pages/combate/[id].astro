---
import HeroEvent from '@/components/Heroevent.astro'
import Layout from '@/layouts/Layout.astro'
import { COMBATS } from '@/consts/combats'
import { TEAMS } from '@/consts/teams'
import { PLAYERS } from '@/consts/fighters'
import Matchstats from '@/components/Matchstats.astro'

const { id } = Astro.params

const combat = COMBATS.find(c => c.id === id)
if (!combat) return Astro.redirect('/combates')

const [team1Id, team2Id] = combat.fighters
const team1Data = TEAMS.find(t => t.id === team1Id)
const team2Data = TEAMS.find(t => t.id === team2Id)
if (!team1Data || !team2Data) return Astro.redirect('/combates')

const team1Players = PLAYERS.filter(p => p.team === team1Id).map(p => ({ id: p.id, name: p.name }))
const team2Players = PLAYERS.filter(p => p.team === team2Id).map(p => ({ id: p.id, name: p.name }))
---
<Layout>
  <HeroEvent
    teamA={{ id: team1Data.id, name: team1Data.name, players: team1Players }}
    teamB={{ id: team2Data.id, name: team2Data.name, players: team2Players }}
    date="SÁB 12 JUL"
    venue="CANCHA LA 93 · BARRANQUILLA"
    eventName="TORNEO JUGADORES"
    edition="PRESENCIAL"
    platform="BARRANQUILLA · COLOMBIA"
  />

<Matchstats
  teamA={{ name: 'LOS VIKINGOS', color: '#00ff88', logo: '/images/logo-a.png' }}
  teamB={{ name: 'LOS GUERREROS', color: '#f59e0b', logo: '/images/logo-b.png' }}
  score={[2, 1]}
  minute={67}
  isLive={true}
  events={[
    { minute: 12, team: 'A', type: 'goal',   player: 'Peereira' },
    { minute: 23, team: 'B', type: 'yellow', player: 'Westcol'  },
    { minute: 52, team: 'B', type: 'red',    player: 'T.Mazza'  },
    { minute: 61, team: 'A', type: 'sub',    player: 'Perxitaa', player2: 'Andoni' },
  ]}
/>
</Layout>
