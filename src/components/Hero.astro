---
import { PLAYERS } from '@/consts/fighters'
import FighterSelector from './FighterSelector.astro'

const { hideLogo, teamLogo } = Astro.props

const firstRow = PLAYERS.slice(0, 6)
const leftRow = firstRow.slice(0, 3)
const rightRow = firstRow.slice(3)
const secondRow = PLAYERS.slice(6)
const allPlayers = PLAYERS
---

<section class="relative flex min-h-screen w-full">
  <div
    class="mask-fade-bottom absolute inset-0 w-full bg-[url('/images/fondo2.png')] bg-cover bg-center"
  >
  </div>

  <div class="group/hero relative flex w-full flex-col items-center p-2 md:p-8 text-center">
    <div
      id="landing"
      class:list={[
        'absolute top-0 flex w-full flex-col items-center py-16',
        'group-has-[a[data-fighter-card]:hover]/hero:hidden group-has-[a[data-fighter-card]:focus]/hero:hidden group-has-[a[data-fighter-card]:focus-visible]/hero:hidden',
      ]}
    >
      <h3
        class="text-theme-seashell animate-fade-in animate-delay-300 mt-4 leading-[100%] font-light"
      >
        <strong>26</strong> DE <br /><strong>JULIO</strong>
      </h3>
      {!hideLogo && (
      <figure class="animate-fade-in relative mt-8">
        <img
          class="relative z-20 h-auto w-64"
          src={teamLogo || "/images/logobg.png"}
          fetchpriority="high"
          alt={teamLogo ? "Logo del equipo" : "La Velada del Año V"}
          decoding="async"
        />
        <div class="absolute top-0 z-0 size-64 bg-emerald-500/80 blur-2xl"></div>
      </figure>
      )}

      <div class="relative z-50">
        <h3
          class="text-theme-seashell animate-fade-in animate-delay-500 z-0 mt-4 leading-[100%] font-light"
        >
          CASA<br />DEL <br /><strong>BEYOND</strong>
        </h3>
        <div class="absolute -inset-2 -z-10 h-full w-full bg-pink-400/80 blur-2xl"></div>
      </div>
    </div>

    <!-- VERSIÓN DESKTOP (original) -->
    <div class="relative hidden h-full w-full max-w-6xl flex-col items-center justify-end gap-4 p-8 pb-2 md:flex">
      <div class="flex w-full flex-wrap justify-between px-4">
        <div class="flex flex-wrap justify-start gap-4">
          {leftRow.map(({ id, name }) => <FighterSelector id={id} name={name} boxerCardClass='animate-fade-in-right animate-delay-500' />)}
        </div>
        <div class="flex flex-wrap justify-end gap-4">
          {rightRow.map(({ id, name }) => <FighterSelector id={id} name={name} boxerCardClass='animate-fade-in-left animate-delay-500' />)}
        </div>
      </div>

      <div class="flex flex-wrap justify-between gap-4">
        {secondRow.map(({ id, name }) => <FighterSelector id={id} name={name} boxerCardClass='animate-fade-in-up animate-delay-700' />)}
      </div>
    </div>

    <!-- VERSIÓN MOBILE (una sola línea con scroll horizontal) -->
    <div class="relative flex h-full w-full flex-col items-center justify-end gap-4 p-4 md:hidden">
      <div class="w-full overflow-x-auto overflow-y-visible pb-2">
        <div class="flex min-w-max items-center justify-start gap-4 px-2">
          {allPlayers.map(({ id, name }) => (
            <FighterSelector 
              id={id} 
              name={name} 
              boxerCardClass='flex-shrink-0' 
            />
          ))}
        </div>
      </div>

    </div>

    <a
      href="/jugadores"
      class="boxer-detail-cta boxer-detail-cta-ghost relative z-10 mt-1"
    >
      VER TODOS LOS JUGADORES
    </a>
  </div>
  </div>
</section>

<style>
  .mask-fade-text {
    mask-image: linear-gradient(to bottom, transparent 5%, black 6%, black 95%, transparent 100%);
  }

  /* Scroll suave para mobile */
  @media (max-width: 768px) {
    .overflow-x-auto {
      scrollbar-width: thin;
      -webkit-overflow-scrolling: touch;
    }
    
    .overflow-x-auto::-webkit-scrollbar {
      height: 3px;
    }
    
    .overflow-x-auto::-webkit-scrollbar-track {
      background: rgba(251, 191, 36, 0.1);
      border-radius: 10px;
    }
    
    .overflow-x-auto::-webkit-scrollbar-thumb {
      background: var(--color-theme-gold);
      border-radius: 10px;
    }
  }

    .boxer-detail-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.3rem;
    border-radius: 9999px;
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 250ms ease,
      background-color 250ms ease,
      color 250ms ease,
      box-shadow 250ms ease;
  }

  @media (min-width: 640px) {
    .boxer-detail-cta {
      font-size: 0.5rem;
      padding: 0.8rem 1.5rem;
    }
  }

  .boxer-detail-cta-ghost {
    background: transparent;
    color: color-mix(in srgb, var(--color-theme-cream) 80%, transparent);

    box-shadow:
      inset 0 0 0 1px
      color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  .boxer-detail-cta-ghost:hover,
  .boxer-detail-cta-ghost:focus-visible {
    color: var(--color-theme-cream);

    box-shadow:
      inset 0 0 0 1px
      color-mix(in srgb, var(--color-theme-gold) 70%, transparent);

    transform: translateY(-1px);
    outline: none;
  }
</style>