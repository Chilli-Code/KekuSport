---
import { TEAMS } from '@/consts/teams'
import FighterSelector from './FighterSelector.astro'

const firstRow = TEAMS.slice(0, 4)
const leftRow = firstRow.slice(0, 2)
const rightRow = firstRow.slice(2)
const secondRow = TEAMS.slice(4)
const allTeams = TEAMS

const teamLogo = '/images/Logo_Default.png'
---

<section class="relative flex min-h-screen w-full">
  <div
    class="mask-fade-bottom absolute inset-0 w-full bg-[url('/images/herp.jpeg')] bg-cover bg-center"
  >
  </div>

  <div class="group/hero relative flex w-full flex-col items-center p-2 md:p-8 text-center">
    <div
      id="landing"
      class:list={[
        'absolute top-0 flex w-full flex-col items-center py-16',
        'group-has-[a[data-fighter-card]:hover]/hero:hidden group-has-[a[data-fighter-card]:focus]/hero:hidden group-has-[a[data-fighter-card]:focus-visible]/hero:hidden',
      ]}
    >
      <h3
        class="text-theme-seashell animate-fade-in animate-delay-300 mt-4 leading-[100%] font-light"
      >
        <strong>TORNEO</strong> DE <br /><strong>EQUIPOS</strong>
      </h3>
      <figure class="animate-fade-in relative mt-8">
        <img
          class="relative z-20 h-auto w-64"
          src="/images/logobg.png"
          fetchpriority="high"
          alt="La Velada del Año V"
          decoding="async"
        />
        <div class="absolute top-0 z-0 size-64 bg-emerald-500/80 blur-2xl"></div>
      </figure>

      <div class="relative z-50">
        <h3
          class="text-theme-seashell animate-fade-in animate-delay-500 z-0 mt-4 leading-[100%] font-light"
        >
          SELECCIONA<br />TU <br /><strong>EQUIPO</strong>
        </h3>
        <div class="absolute -inset-2 -z-10 h-full w-full bg-pink-400/80 blur-2xl"></div>
      </div>
    </div>

    <!-- VERSIÓN DESKTOP -->
    <div class="relative hidden h-full w-full max-w-6xl flex-col items-center justify-end gap-4 p-8 md:flex">
      <div class="flex w-full flex-wrap justify-between px-4">
        <div class="flex flex-wrap justify-start gap-4">
          {leftRow.map(({ id, name }) => (
            <FighterSelector
              id={id}
              name={name}
              cardLink={`/jugadores/${id}`}
              cardImage={teamLogo}
              bigImageSrc={teamLogo}
              boxerCardClass='animate-fade-in-right animate-delay-500'
            />
          ))}
        </div>
        <div class="flex flex-wrap justify-end gap-4">
          {rightRow.map(({ id, name }) => (
            <FighterSelector
              id={id}
              name={name}
              cardLink={`/jugadores/${id}`}
              cardImage={teamLogo}
              bigImageSrc={teamLogo}
              boxerCardClass='animate-fade-in-left animate-delay-500'
            />
          ))}
        </div>
      </div>

      <div class="flex flex-wrap justify-between gap-4">
        {secondRow.map(({ id, name }) => (
          <FighterSelector
            id={id}
            name={name}
            cardLink={`/jugadores/${id}`}
            cardImage={teamLogo}
            bigImageSrc={teamLogo}
            boxerCardClass='animate-fade-in-up animate-delay-700'
          />
        ))}
      </div>
    </div>

    <!-- VERSIÓN MOBILE -->
    <div class="relative flex h-full w-full flex-col items-center justify-end gap-4 p-4 md:hidden">
      <div class="w-full overflow-x-auto overflow-y-visible pb-2">
        <div class="flex min-w-max items-center justify-start gap-4 px-2">
          {allTeams.map(({ id, name }) => (
            <FighterSelector
              id={id}
              name={name}
              cardLink={`/jugadores/${id}`}
              cardImage={teamLogo}
              bigImageSrc={teamLogo}
              boxerCardClass='flex-shrink-0'
            />
          ))}
        </div>
      </div>

      <div class="mt-0.5 flex items-center justify-center gap-2">
        <svg class="h-3 w-3 text-theme-gold/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="text-[0.5rem] uppercase tracking-wider text-theme-gold/50">Desliza</span>
        <svg class="h-3 w-3 text-theme-gold/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .mask-fade-text {
    mask-image: linear-gradient(to bottom, transparent 5%, black 6%, black 95%, transparent 100%);
  }

  @media (max-width: 768px) {
    .overflow-x-auto {
      scrollbar-width: thin;
      -webkit-overflow-scrolling: touch;
    }

    .overflow-x-auto::-webkit-scrollbar {
      height: 3px;
    }

    .overflow-x-auto::-webkit-scrollbar-track {
      background: rgba(251, 191, 36, 0.1);
      border-radius: 10px;
    }

    .overflow-x-auto::-webkit-scrollbar-thumb {
      background: var(--color-theme-gold);
      border-radius: 10px;
    }
  }
</style>
