---
import Logo from "@/assets/svg/logo.svg";
import { TEAMS } from '@/consts/teams'

const { player } = Astro.props;

const generateRandomBars = () => {
  const bars = [];
  for (let i = 0; i < 20; i++) {
    bars.push(Math.floor(Math.random() * (2 - 1 + 1)) + 2);
  }
  return bars;
};

const bars = generateRandomBars();
const team = TEAMS.find((t) => t.id === player.team)


---

<article class="boxer-profile-card group relative
w-[92%]
sm:w-[88%]
md:w-full
lg:max-w-[450px]
overflow-hidden rounded-xl
bg-theme-midnight/70 backdrop-blur-xs
transition-all duration-500">
  
  <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent transition-transform duration-700 ease-in-out group-hover:translate-x-full"></div>

  <main class="grid gap-0">
    <div class="flex flex-wrap items-center gap-2 p-4 pb-0 animate-fade-in-up">
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-emerald-500/20 backdrop-blur-sm border border-emerald-500/30 text-emerald-300">
        {player.neighborhood}
      </span>
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-purple-500/20 backdrop-blur-sm border border-purple-500/30 text-purple-300">
        {player.position}
      </span>
    </div>

    <div class="flex flex-col p-4">
      <div class="mb-3">
        <div class="inline-block border-l-3 border-theme-gold pl-2">
          <div class="h-auto w-auto">
            <h3 class="boxer-detail-name text-5xl font-black uppercase tracking-wider relative z-10 sm:text-6xl md:text-7xl">
              {player.name}
            </h3>
            <div class="absolute inset-0 bg-theme-gold/40 blur-2xl -z-0 opacity-20 group-hover:opacity-40 transition-opacity duration-500 rounded-xl"></div>
          </div>
        </div>
      </div>

      {team && (
        <div class="flex items-center gap-2 mt-1 mb-2">
          <span class="text-[0.55rem] font-bold tracking-[0.3em] text-theme-gold/70 uppercase">
            {team.name}
          </span>
        </div>
      )}

      <div class="flex w-full items-center gap-3 sm:gap-4 my-4" aria-hidden="true">
        <span class="size-1 rotate-45 bg-theme-gold/70"></span>
        <span class="h-px flex-1 bg-linear-to-r from-theme-gold/45 to-transparent"></span>
      </div>

      <div class="grid grid-cols-3 gap-2 mt-2">
        <div class="stat-item">
          <span class="text-[0.5rem] font-bold tracking-[0.2em] text-theme-gold/70 uppercase">
            Edad
          </span>
          <p class="font-cinzel text-base font-bold text-theme-cream">
            {player.age} <span class="text-xs font-normal text-theme-cream/60">años</span>
          </p>
        </div>
        <div class="stat-item">
          <span class="text-[0.5rem] font-bold tracking-[0.2em] text-theme-gold/70 uppercase">
            Dorsal
          </span>
          <p class="font-cinzel text-base font-bold text-theme-cream">
            #{player.number}
          </p>
        </div>
        <div class="stat-item">
          <span class="text-[0.5rem] font-bold tracking-[0.2em] text-theme-gold/70 uppercase">
            Posición
          </span>
          <p class="font-cinzel text-base font-bold text-theme-cream">
            {player.position}
          </p>
        </div>
        <div class="stat-item">
          <span class="text-[0.5rem] font-bold tracking-[0.2em] text-theme-gold/70 uppercase">
            Barrio
          </span>
          <p class="font-cinzel text-base font-bold text-theme-cream">
            {player.neighborhood}
          </p>
        </div>
        <div class="stat-item">
          <span class="text-[0.5rem] font-bold tracking-[0.2em] text-theme-gold/70 uppercase">
            Pie Hábil
          </span>
          <p class="font-cinzel text-base font-bold text-theme-cream">
            {player.preferredFoot}
          </p>
        </div>
      </div>

      <div class="mt-4 p-3 rounded-lg border border-theme-gold/15 bg-theme-midnight/50">
        <p class="font-cinzel text-xs leading-relaxed tracking-wide text-theme-cream/80 italic">
          "{player.bio}"
        </p>
      </div>
    </div>
  </main>

  <footer class="flex items-center flex-col justify-between border-t border-theme-gold/20 bg-theme-midnight/80 px-4 py-2">
    <div class="w-full flex justify-between mt-2">
      <div class="flex items-center gap-2">
        <span class="font-cinzel text-xs font-bold uppercase tracking-wide text-theme-cream/80">
          {player.city} · {player.neighborhood}
        </span>
      </div>

      <div class="flex items-center gap-2">
        <Logo class="h-5 w-auto text-theme-gold" />
        <div class="flex items-end bg-theme-cream/90 pl-0.5 py-0.5 rounded-sm">
          {bars.map((width, index) => (
            <span 
              key={index}
              class="bg-theme-midnight h-[20px] mr-0.5 transition-all duration-300 group-hover:bg-theme-gold" 
              style={`width: ${width}px;`}
            ></span>
          ))}
        </div>
      </div>

    </div>

  </footer>
</article>

<style>
  .stat-item {
    animation: fadeInUp 0.4s ease-out forwards;
    opacity: 0;
  }

  .stat-item:nth-child(1) { animation-delay: 0.1s; }
  .stat-item:nth-child(2) { animation-delay: 0.2s; }
  .stat-item:nth-child(3) { animation-delay: 0.3s; }
  .stat-item:nth-child(4) { animation-delay: 0.4s; }
  .stat-item:nth-child(5) { animation-delay: 0.5s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .boxer-detail-name {
    color: #fef3c7;
    background: linear-gradient(
      180deg,
      #fef3c7 0%,
      #fef3c7 50%,
      #fbbf24 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 
      0 0 1px rgba(254, 243, 199, 0.6),
      0 2px 18px rgba(251, 191, 36, 0.55),
      0 6px 40px rgba(251, 191, 36, 0.25);
  }
</style>
