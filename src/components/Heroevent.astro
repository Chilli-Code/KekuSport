---
export interface Player {
  id: string
  name: string
  img?: string
  isCaptain?: boolean
}

export interface Team {
  id: string
  name: string
  color?: string
  logo?: string
  players: Player[]
}

export interface Props {
  teamA: Team
  teamB: Team
  date?: string
  venue?: string
  eventName?: string
  edition?: string
  platform?: string
}

const {
  date      = "26 DE JULIO",
  venue     = "ESTADIO LA CARTUJA · SEVILLA",
  eventName = "LA VELADA",
  edition   = "V",
  platform  = "TWITCH.TV/IBAI",
  teamA = {
    id: 'team-a', name: 'LOS VIKINGOS', color: '#00ff88',
    players: [
      { id: 'p1', name: 'PEEREIRA7', isCaptain: true },
      { id: 'p2', name: 'PERXITAA' },
      { id: 'p3', name: 'ABBY' },
      { id: 'p4', name: 'ANDONI' },
      { id: 'p5', name: 'ALANA' },
    ],
  },
  teamB = {
    id: 'team-b', name: 'LOS GUERREROS', color: '#f59e0b',
    players: [
      { id: 'p6', name: 'THEGREFG', isCaptain: true },
      { id: 'p7', name: 'WESTCOL' },
      { id: 'p8', name: 'VIRUZZ' },
      { id: 'p9', name: 'T. MAZZA' },
      { id: 'p10', name: 'ARIGELI' },
    ],
  },
} = Astro.props

const colorA = teamA.color ?? '#00ff88'
const colorB = teamB.color ?? '#f59e0b'
---

<section class="vs-root" aria-label={`${teamA.name} vs ${teamB.name}`}>

  <!-- ═══ FONDO ═══ -->
  <div class="vs-bg" aria-hidden="true">
    <div class="vs-bg-base"></div>
    <div class="vs-rays"></div>
    <div class="vs-glow-a" style={`background:radial-gradient(ellipse,${colorA}22 0%,transparent 70%)`}></div>
    <div class="vs-glow-b" style={`background:radial-gradient(ellipse,${colorB}22 0%,transparent 70%)`}></div>
    <div class="vs-glow-top"></div>
    <div class="vs-stars"></div>
    <div class="vs-field-arc"></div>
    <div class="vs-center-line"></div>
  </div>

  <!-- ═══ EQUIPO A ═══ -->
  <div class="vs-side vs-side--a">
    <div class="vs-side-glow" style={`background:radial-gradient(ellipse at 80% 60%,${colorA}18 0%,transparent 65%)`}></div>
<div class="vs-team-header vs-team-header--a">
  <div class="vs-team-logo-wrap">
    <img src={teamA.logo ?? '/images/Logo_Default.png'} alt={teamA.name} class="vs-team-logo" />
  </div>
  <div class="vs-team-namebar" style={`border-color:${colorA}44;background:${colorA}0f`}>
    <span style={`color:${colorA}`}>{teamA.name}</span>
  </div>
</div>
    <div class="vs-players vs-players--a">
      {teamA.players.map((p, i) => (
        <div
          class={`vs-player vs-player--a ${p.isCaptain ? 'vs-player--captain' : ''}`}
          data-index={i}
          style={`--i:${i};--color:${colorA};animation-delay:${i * 0.08}s`}
        >
          <div class="vs-player-img-wrap">
            {p.img
              ? <img src={p.img} alt={p.name} class="vs-player-img" loading="eager" />
              :<img
  src={`/images/fighters/big/jugador_mistery.webp`}
  alt={p.name}
  class="vs-player-img"
  loading="eager"
/>
            }
            {p.isCaptain && (
              <div class="vs-captain-ring" style={`border-color:${colorA};box-shadow:0 0 16px ${colorA}88`}></div>
            )}
            <div class="vs-player-fade vs-player-fade--a"></div>
          </div>
          <span class="vs-player-name" style={`color:${p.isCaptain ? colorA : 'var(--cream)'}`}>{p.name}</span>
        </div>
      ))}
    </div>
<!-- 
    <div class="vs-team-name vs-team-name--a" style={`color:${colorA};text-shadow:0 0 30px ${colorA}88`}>
      {teamA.name}
    </div> -->
  </div>

  <!-- ═══ CENTRO ═══ -->
  <div class="vs-center">
    <p class="vs-date">{date}</p>

    <div class="vs-event-wrap">
      <span class="vs-spark vs-spark--tl"></span>
      <span class="vs-spark vs-spark--tr"></span>
      <span class="vs-spark vs-spark--bl"></span>
      <span class="vs-spark vs-spark--br"></span>
      <div class="vs-event-name">
        <span class="vs-event-small">{eventName}</span>
        <span class="vs-event-edition">{edition}</span>
      </div>
    </div>

    <div class="vs-badge">
      <div class="vs-badge-ring"></div>
      <span class="vs-badge-text">VS</span>
    </div>

    <div class="vs-meta">
      <span class="vs-meta-venue">{venue}</span>
      <span class="vs-meta-platform">{platform}</span>
    </div>
  </div>

  <!-- ═══ EQUIPO B ═══ -->
  <div class="vs-side vs-side--b">
    <div class="vs-side-glow" style={`background:radial-gradient(ellipse at 20% 60%,${colorB}18 0%,transparent 65%)`}></div>
<div class="vs-team-header vs-team-header--b">
  <div class="vs-team-logo-wrap">
    <img src={teamB.logo ?? '/images/Logo_Default.png'} alt={teamB.name} class="vs-team-logo" />
  </div>
  <div class="vs-team-namebar" style={`border-color:${colorB}44;background:${colorB}0f`}>
    <span style={`color:${colorB}`}>{teamB.name}</span>
  </div>
</div>
    <div class="vs-players vs-players--b">
      {teamB.players.map((p, i) => (
        <div
          class={`vs-player vs-player--b ${p.isCaptain ? 'vs-player--captain' : ''}`}
          data-index={i}
          style={`--i:${i};--color:${colorB};animation-delay:${i * 0.08 + 0.1}s`}
        >
          <div class="vs-player-img-wrap">
            {p.img
              ? <img src={p.img} alt={p.name} class="vs-player-img vs-player-img--flip" loading="eager" />
              :<img
  src={`/images/fighters/big/jugador_mistery.webp`}
  alt={p.name}
  class="vs-player-img"
  loading="eager"
/>
            }
            {p.isCaptain && (
              <div class="vs-captain-ring" style={`border-color:${colorB};box-shadow:0 0 16px ${colorB}88`}></div>
            )}
            <div class="vs-player-fade vs-player-fade--b"></div>
          </div>
          <span class="vs-player-name" style={`color:${p.isCaptain ? colorB : 'var(--cream)'}`}>{p.name}</span>
        </div>
      ))}
    </div>
<!-- 
    <div class="vs-team-name vs-team-name--b" style={`color:${colorB};text-shadow:0 0 30px ${colorB}88`}>
      {teamB.name}
    </div> -->
  </div>

</section>

<style>
  :root {
    --midnight: var(--color-theme-midnight, #0a0e1a);
    --gold:     var(--color-theme-gold, #fbbf24);
    --cream:    var(--color-theme-cream, #e8dcc8);
    --green:    #00ff88;
  }

  /* ══ RAÍZ ══ */
  .vs-root {
    position: relative;
    width: 100%;
  min-height: 100vh;
  min-height: 100dvh;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    overflow: hidden;

    isolation: isolate;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
  }

  /* ══ FONDO ══ */
  .vs-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }

  .vs-bg-base {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, #0b2a1a 0%, #060d0a 45%, #03080e 100%);
  }
  .vs-rays {
    position: absolute; inset: 0;
    background: conic-gradient(
      from 270deg at 50% -10%,
      transparent 55deg, rgba(0,255,136,.035) 65deg, transparent 75deg,
      rgba(199,168,107,.03) 80deg, transparent 90deg,
      rgba(0,255,136,.025) 95deg, transparent 105deg
    );
  }
  .vs-glow-a {
    position: absolute; top: 0; left: -5%; width: 50%; height: 70%;
    filter: blur(70px);
    animation: glowSide 6s ease-in-out infinite alternate;
  }
  .vs-glow-b {
    position: absolute; top: 0; right: -5%; width: 50%; height: 70%;
    filter: blur(70px);
    animation: glowSide 7s ease-in-out infinite alternate-reverse;
  }
  .vs-glow-top {
    position: absolute; top: -15%; left: 50%; transform: translateX(-50%);
    width: 40%; height: 40%;
    background: radial-gradient(ellipse, rgba(0,255,136,.12) 0%, transparent 70%);
    filter: blur(50px);
    animation: glowTop 5s ease-in-out infinite alternate;
  }
  @keyframes glowSide { 0%{opacity:.3} 100%{opacity:.8} }
  @keyframes glowTop  {
    0%   { opacity:.4; transform: translateX(-50%) scale(1); }
    100% { opacity:.9; transform: translateX(-50%) scale(1.1); }
  }

  .vs-stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 7%  15%, #fff, transparent),
      radial-gradient(1px   1px   at 25% 58%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 50% 10%, #a855f7, transparent),
      radial-gradient(1px   1px   at 70% 75%, #fff, transparent),
      radial-gradient(2px   2px   at 88% 35%, #00ff88, transparent),
      radial-gradient(1px   1px   at 16% 85%, #c084fc, transparent),
      radial-gradient(1.5px 1.5px at 60% 50%, #fff, transparent),
      radial-gradient(1px   1px   at 42% 30%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 93%  8%, #fff, transparent);
    background-size: 260px 260px;
    opacity: .45;
    animation: twinkle 7s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0%{opacity:.2} 100%{opacity:.55} }

  .vs-field-arc {
    position: absolute; bottom: -6vw; left: 50%; transform: translateX(-50%);
    width: 60vw; height: 16vw;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    border: 1px solid rgba(0,255,136,.08);
  }
  .vs-center-line {
    position: absolute; top: 0; bottom: 0; left: 50%; width: 1px;
    background: linear-gradient(to bottom,
      transparent, rgba(0,255,136,.12) 30%, rgba(0,255,136,.07) 60%, transparent
    );
  }

  /* ══ LADOS ══ */
  .vs-side {
    position: relative;
  height: 100vh;
  height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    z-index: 1;
    overflow: hidden;
  }
  .vs-side--a { align-items: flex-start; padding: 0 0 2rem 1.5rem; }
  .vs-side--b { align-items: flex-end;   padding: 0 1.5rem 2rem 0; }

  .vs-side-glow { position: absolute; inset: 0; pointer-events: none; }

  /* ══ JUGADORES ══ */
  .vs-players {
    position: absolute; inset: 0;
    display: flex;
    align-items: flex-end;
    pointer-events: none;
  }
  .vs-players--a { justify-content: flex-start; }
  .vs-players--b { justify-content: flex-end; }

  .vs-player {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: playerIn .8s cubic-bezier(.22,1,.36,1) both;
  }

  /* Overlap en abanico */
  .vs-players--a .vs-player[data-index="0"] { z-index: 5; }
  .vs-players--a .vs-player[data-index="1"] { z-index: 4; margin-left: -2rem; }
  .vs-players--a .vs-player[data-index="2"] { z-index: 3; margin-left: -3rem; }
  .vs-players--a .vs-player[data-index="3"] { z-index: 2; margin-left: -3rem; }
  .vs-players--a .vs-player[data-index="4"] { z-index: 1; margin-left: -3rem; }

  .vs-players--b .vs-player[data-index="0"] { z-index: 5; order: 5; }
  .vs-players--b .vs-player[data-index="1"] { z-index: 4; order: 4; margin-right: -2rem; }
  .vs-players--b .vs-player[data-index="2"] { z-index: 3; order: 3; margin-right: -3rem; }
  .vs-players--b .vs-player[data-index="3"] { z-index: 2; order: 2; margin-right: -3rem; }
  .vs-players--b .vs-player[data-index="4"] { z-index: 1; order: 1; margin-right: -3rem; }

  @keyframes playerIn {
    from { opacity: 0; transform: translateY(40px) scale(.9); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Tamaños: capitán grande, resto escalonado */
  .vs-player--captain .vs-player-img-wrap {
    width: clamp(110px, 17vw, 250px);
    height: clamp(190px, 52vh, 500px);
  }
  .vs-player:not(.vs-player--captain) .vs-player-img-wrap {
    width: clamp(72px, 10vw, 150px);
    height: clamp(124px, 33vh, 316px);
  }
  /* Escala decreciente por posición */
  .vs-player[data-index="2"] .vs-player-img-wrap { transform: scale(.9); transform-origin: bottom; }
  .vs-player[data-index="3"] .vs-player-img-wrap { transform: scale(.8); transform-origin: bottom; }
  .vs-player[data-index="4"] .vs-player-img-wrap { transform: scale(.72); transform-origin: bottom; }

  .vs-player-img-wrap { position: relative; overflow: hidden; }

  .vs-player-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top center;
    filter: drop-shadow(0 0 30px rgba(0,0,0,.6));
  }
  .vs-player-img--flip { transform: scaleX(-1); }

  .vs-player-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(160deg, color-mix(in srgb,var(--color) 15%,#0a0e1a) 0%, #0a0e1a 100%);
    border-top: 2px solid color-mix(in srgb, var(--color) 40%, transparent);
  }
  .vs-player-initial {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(2rem, 6vw, 5rem);
    font-weight: 900;
    color: var(--color);
    opacity: .6;
    filter: drop-shadow(0 0 20px var(--color));
  }

  .vs-captain-ring {
    position: absolute; inset: -3px;
    border: 2px solid;
    pointer-events: none;
    animation: ringPulse 2.5s ease-in-out infinite;
  }
  @keyframes ringPulse { 0%,100%{opacity:.5} 50%{opacity:1} }

  /* Fades */
  .vs-player-fade { position: absolute; inset: 0; pointer-events: none; }
  .vs-player-fade--a {
    background: linear-gradient(to right, var(--midnight) 0%, transparent 35%, transparent 70%, rgba(10,14,26,.3) 100%);
  }
  .vs-player-fade--b {
    background: linear-gradient(to left, var(--midnight) 0%, transparent 35%, transparent 70%, rgba(10,14,26,.3) 100%);
  }
  .vs-player-img-wrap::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 30%;
    background: linear-gradient(to top, var(--midnight) 0%, transparent 100%);
    pointer-events: none;
  }

  .vs-player-name {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(.42rem, 1vw, .65rem);
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-top: .3rem;
    text-shadow: 0 0 12px currentColor;
    white-space: nowrap;
    position: relative; z-index: 10;
  }

  .vs-team-name {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(.9rem, 2.5vw, 1.6rem);
    font-weight: 900;
    letter-spacing: .18em;
    text-transform: uppercase;
    position: relative; z-index: 10;
    margin-top: .5rem;
  }
  .vs-team-name--a { text-align: left; }
  .vs-team-name--b { text-align: right; }

  /* ══ CENTRO ══ */
  .vs-center {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .6rem;
    padding: clamp(1rem, 4vh, 2.5rem) clamp(.75rem, 2vw, 1.5rem);
    min-width: clamp(130px, 18vw, 240px);
    text-align: center;
  }

  .vs-date {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(.45rem, 1.2vw, .7rem);
    font-weight: 700;
    letter-spacing: .3em;
    color: color-mix(in srgb, var(--gold) 70%, transparent);
    animation: fadeDown .6s .3s both;
  }

  .vs-event-wrap {
    position: relative;
    padding: .4rem .75rem;
    animation: fadeDown .7s .4s both;
  }
  .vs-spark {
    position: absolute;
    width: 5px; height: 5px;
    background: var(--gold);
    transform: rotate(45deg);
    opacity: .8;
    animation: sparkle 3s ease-in-out infinite alternate;
  }
  .vs-spark--tl { top: 0; left: 0; animation-delay: 0s; }
  .vs-spark--tr { top: 0; right: 0; animation-delay: .6s; }
  .vs-spark--bl { bottom: 0; left: 0; animation-delay: 1.2s; }
  .vs-spark--br { bottom: 0; right: 0; animation-delay: 1.8s; }
  @keyframes sparkle {
    0%   { opacity:.2; transform: rotate(45deg) scale(.7); }
    100% { opacity:1;  transform: rotate(45deg) scale(1.3); box-shadow: 0 0 8px var(--gold); }
  }

  .vs-event-name { display: flex; flex-direction: column; align-items: center; gap: .05em; }
  .vs-event-small {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(.45rem, 1.5vw, .7rem);
    font-weight: 600;
    letter-spacing: .4em;
    color: color-mix(in srgb, var(--cream) 55%, transparent);
  }
  .vs-event-edition {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(1.8rem, 6vw, 3.5rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(180deg, #fef3c7 0%, #fef3c7 40%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 16px rgba(251,191,36,.5));
  }

  /* VS badge */
  .vs-badge {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    width: clamp(54px, 8vw, 90px);
    height: clamp(54px, 8vw, 90px);
    animation: fadeDown .7s .5s both;
  }
  .vs-badge-ring {
    position: absolute; inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(0,255,136,.5);
    background: radial-gradient(ellipse, rgba(0,255,136,.08) 0%, transparent 70%);
    animation: ringSpin 8s linear infinite;
  }
  .vs-badge-ring::before {
    content: '';
    position: absolute; top: -3px; left: 50%; transform: translateX(-50%);
    width: 6px; height: 6px;
    background: #00ff88; border-radius: 50%;
    box-shadow: 0 0 10px #00ff88;
  }
  @keyframes ringSpin { from{transform:rotate(0)} to{transform:rotate(360deg)} }

  .vs-badge-text {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(1rem, 3vw, 1.8rem);
    font-weight: 900;
    letter-spacing: .05em;
    color: #00ff88;
    filter: drop-shadow(0 0 12px rgba(0,255,136,.8)) drop-shadow(0 0 30px rgba(0,255,136,.4));
    animation: vsPulse 2s ease-in-out infinite alternate;
    position: relative; z-index: 1;
  }
  @keyframes vsPulse {
    0%   { filter: drop-shadow(0 0 8px rgba(0,255,136,.5)); }
    100% { filter: drop-shadow(0 0 20px rgba(0,255,136,1)) drop-shadow(0 0 40px rgba(0,255,136,.5)); }
  }

  .vs-meta {
    display: flex; flex-direction: column; align-items: center; gap: .15rem;
    animation: fadeDown .7s .65s both;
  }
  .vs-meta-venue {
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    font-size: clamp(.38rem, 1vw, .55rem);
    font-weight: 700;
    letter-spacing: .15em;
    color: color-mix(in srgb, var(--cream) 55%, transparent);
    text-transform: uppercase;
    text-align: center;
  }
  .vs-meta-platform {
    font-family: monospace;
    font-size: clamp(.35rem, .9vw, .52rem);
    letter-spacing: .12em;
    color: #00ff88;
    opacity: .75;
  }

  @keyframes fadeDown {
    from { opacity:0; transform: translateY(-10px); }
    to   { opacity:1; transform: translateY(0); }
  }

  /* ══ MOBILE ══ */
@media (max-width: 600px) {

  .vs-root {
    display: flex;
    flex-direction: column;
    gap:25px;
    width: 100%;
    
    min-height: 100vh;
    min-height: 100dvh;

    overflow: hidden;

    padding: 0;
    margin: 0;
  }

  .vs-center-line {
    display: none;
  }

  /* =========================
     SIDE
  ========================= */

  .vs-side {
    position: relative;

    width: 100%;
    height: 220px;

    display: flex;
    align-items: flex-end;
    justify-content: center;

    overflow: visible;

    padding: 0 !important;
    margin: 0;
  }

  .vs-side--a {
    margin-top: auto;
  }

  .vs-side--b {
    margin-top: -0.5rem;
  }

  /* =========================
     ESCUDO
  ========================= */

  .vs-team-header {
    position: absolute !important;

    top: 0;
    left: 50%;

    transform: translateX(-50%) !important;

    z-index: 100;

    display: flex;
    flex-direction: column;

    align-items: center;
    justify-content: center;

    pointer-events: none;
  }

  .vs-team-logo-wrap {
    width: 88px;
    height: 88px;

    border-radius: 14px;

    background: rgba(0,0,0,.75);

    border: 1px solid rgba(255,255,255,.14);

    box-shadow:
      0 0 20px rgba(0,0,0,.5),
      0 0 14px rgba(0,255,136,.18);

    overflow: hidden;

    display: flex;
    align-items: center;
    justify-content: center;

    position: relative;
    z-index: 101;
  }

  .vs-team-logo {
    width: 64px;
    height: 64px;

    object-fit: contain;

    display: block;
  }

  .vs-team-namebar {
    margin-top: -0.4rem;

    padding: 0.12rem 0.55rem;

    border-radius: 4px;

    position: relative;
    z-index: 102;

    background: rgba(0,0,0,.55);
