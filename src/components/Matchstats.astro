---
export interface TeamStat {
  logo?: string
  name: string
  color?: string
}

export interface StatRow {
  label: string
  valueA: number | string
  valueB: number | string
  type?: 'bar' | 'number' | 'percent' | 'cards'
  highlight?: boolean   // resalta el mayor
}

export interface MatchEvent {
  minute: number
  team: 'A' | 'B'
  type: 'goal' | 'yellow' | 'red' | 'sub' | 'var'
  player: string
  player2?: string  // para sustituciones
}

export interface Props {
  teamA: TeamStat
  teamB: TeamStat
  score?: [number, number]
  minute?: number
  isLive?: boolean
  stats?: StatRow[]
  events?: MatchEvent[]
}

const {
  teamA = { name: 'LOS VIKINGOS', color: '#00ff88' },
  teamB = { name: 'LOS GUERREROS', color: '#f59e0b' },
  score = [2, 1],
  minute = 67,
  isLive = true,
  stats = [
    { label: 'Posesión',               valueA: '58%', valueB: '42%', type: 'bar',     highlight: true },
    { label: 'Remates',                valueA: 14,    valueB: 8,     type: 'bar',     highlight: true },
    { label: 'Remates al arco',        valueA: 6,     valueB: 3,     type: 'bar',     highlight: true },
    { label: 'Pases',                  valueA: 312,   valueB: 224,   type: 'bar',     highlight: true },
    { label: 'Precisión de pase',      valueA: '84%', valueB: '71%', type: 'bar',     highlight: true },
    { label: 'Faltas cometidas',       valueA: 8,     valueB: 12,    type: 'bar',     highlight: false },
    { label: 'Tarjetas amarillas',     valueA: 2,     valueB: 3,     type: 'cards' },
    { label: 'Tarjetas rojas',         valueA: 0,     valueB: 1,     type: 'cards' },
    { label: 'Fuera de juego',         valueA: 3,     valueB: 1,     type: 'number' },
    { label: 'Tiros de esquina',       valueA: 5,     valueB: 4,     type: 'number' },
    { label: 'Salvadas',               valueA: 2,     valueB: 4,     type: 'number' },
    { label: 'Cambios realizados',     valueA: 2,     valueB: 3,     type: 'number' },
  ],
  events = [
    { minute: 12, team: 'A', type: 'goal',   player: 'Peereira'  },
    { minute: 23, team: 'B', type: 'yellow', player: 'Westcol'   },
    { minute: 38, team: 'A', type: 'yellow', player: 'Abby'      },
    { minute: 45, team: 'B', type: 'goal',   player: 'TheGrefg'  },
    { minute: 52, team: 'B', type: 'red',    player: 'T.Mazza'   },
    { minute: 58, team: 'A', type: 'goal',   player: 'Viruzz'    },
    { minute: 61, team: 'A', type: 'sub',    player: 'Perxitaa', player2: 'Andoni' },
    { minute: 65, team: 'B', type: 'sub',    player: 'Rubius',   player2: 'Arigeli'},
  ],
} = Astro.props

const cA = teamA.color ?? '#00ff88'
const cB = teamB.color ?? '#f59e0b'

// Para barras: convierte valor a número
function toNum(v: number | string): number {
  if (typeof v === 'number') return v
  return parseFloat(v.replace('%', ''))
}

// Porcentaje de barra para cada lado
function barA(a: number | string, b: number | string): number {
  const na = toNum(a), nb = toNum(b)
  const total = na + nb
  return total === 0 ? 50 : Math.round((na / total) * 100)
}

const eventIcons: Record<string, string> = {
  goal: '⚽', yellow: '🟨', red: '🟥', sub: '🔄', var: '📺'
}

const eventsA = events.filter(e => e.team === 'A')
const eventsB = events.filter(e => e.team === 'B')
---

<div class="ms-root !my-20 mx-2 sm:mx-6 lg:mx-10">

  <!-- ══ FONDO ══ -->
  <div class="ms-bg " aria-hidden="true">
    <div class="ms-bg-glow-a" style={`background:radial-gradient(ellipse,${cA}14 0%,transparent 65%)`}></div>
    <div class="ms-bg-glow-b" style={`background:radial-gradient(ellipse,${cB}14 0%,transparent 65%)`}></div>
    <div class="ms-stars"></div>
    <div class="ms-scanlines"></div>
  </div>

  <!-- ══ MARCADOR HEADER ══ -->
  <header class="ms-header flex items-center justify-center">

    <!-- Marcador central -->
    <div class="ms-scoreboard">
      <div class="ms-score-wrap">
        <span class="ms-score" style={`color:${cA};text-shadow:0 0 24px ${cA}88`}>{score[0]}</span>
        <div class="ms-score-divider">
          {isLive && (
            <div class="ms-live-dot-wrap">
              <span class="ms-live-dot"></span>
              <span class="ms-live-label">EN VIVO</span>
            </div>
          )}
          <span class="ms-score-sep">—</span>
          <div class="ms-minute-badge">
            <span class="ms-minute-num">{minute}'</span>
          </div>
        </div>
        <span class="ms-score" style={`color:${cB};text-shadow:0 0 24px ${cB}88`}>{score[1]}</span>
      </div>

      <!-- Barra de tiempo -->
      <div class="ms-time-bar">
        <div class="ms-time-fill" style={`width:${Math.min((minute/90)*100,100)}%`}></div>
        <div class="ms-time-dot" style={`left:${Math.min((minute/90)*100,100)}%`}></div>
      </div>
      <div class="ms-time-labels">
        <span>0'</span><span>45'</span><span>90'</span>
      </div>
    </div>


  </header>

  <!-- ══ EVENTOS DEL PARTIDO (línea de tiempo) ══ -->
  <div class="ms-events-wrap">
    <div class="ms-events-title">
      <span class="ms-section-diamond"></span>
      <span>EVENTOS DEL PARTIDO</span>
      <span class="ms-section-diamond"></span>
    </div>

    <div class="ms-events-timeline">
      <!-- Línea central -->
      <div class="ms-timeline-line"></div>

      {events.sort((a,b) => a.minute - b.minute).map(ev => (
        <div class={`ms-event ms-event--${ev.team.toLowerCase()}`}>
          <!-- Lado A -->
          <div class="ms-event-side ms-event-side--a">
            {ev.team === 'A' && (
              <div class="ms-event-content ms-event-content--a">
                <span class="ms-event-player">{ev.player}</span>
                {ev.type === 'sub' && ev.player2 && (
                  <span class="ms-event-sub">↑ {ev.player2}</span>
                )}
              </div>
            )}
          </div>

          <!-- Centro: minuto + icono -->
          <div class="ms-event-mid">
            <span class="ms-event-min">{ev.minute}'</span>
            <div class={`ms-event-icon ms-event-icon--${ev.type}`}>
              {eventIcons[ev.type]}
            </div>
          </div>

          <!-- Lado B -->
          <div class="ms-event-side ms-event-side--b">
            {ev.team === 'B' && (
              <div class="ms-event-content ms-event-content--b">
                <span class="ms-event-player">{ev.player}</span>
                {ev.type === 'sub' && ev.player2 && (
                  <span class="ms-event-sub">↑ {ev.player2}</span>
                )}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ══ ESTADÍSTICAS ══ -->
  <div class="ms-stats-wrap">
    <div class="ms-events-title">
      <span class="ms-section-diamond"></span>
      <span>ESTADÍSTICAS</span>
      <span class="ms-section-diamond"></span>
    </div>

    <div class="ms-stats-list">
      {stats.map((row) => {
        const pctA = barA(row.valueA, row.valueB)
        const pctB = 100 - pctA
        const aWins = toNum(row.valueA) > toNum(row.valueB)
        const bWins = toNum(row.valueB) > toNum(row.valueA)

        return (
          <div class={`ms-stat-row ${row.type === 'cards' ? 'ms-stat-row--cards' : ''}`}>

            <!-- Valor A -->
            <div class="ms-stat-val ms-stat-val--a">
              {row.type === 'cards' ? (
                <div class="ms-cards">
                  {Array.from({ length: toNum(row.valueA) }, () => (
                    <span class={`ms-card ${row.label.includes('roja') ? 'ms-card--red' : 'ms-card--yellow'}`}></span>
                  ))}
                  {toNum(row.valueA) === 0 && <span class="ms-cards-zero">—</span>}
                </div>
              ) : (
                <span
                  class={`ms-val-text ${aWins && row.highlight ? 'ms-val--win' : ''}`}
                  style={aWins && row.highlight ? `color:${cA};text-shadow:0 0 12px ${cA}66` : ''}
                >
                  {row.valueA}
                </span>
              )}
            </div>

            <!-- Etiqueta + barra -->
            <div class="ms-stat-center">
              <span class="ms-stat-label">{row.label}</span>
              {row.type === 'bar' && (
                <div class="ms-bar">
                  <div
                    class="ms-bar-a"
                    style={`width:${pctA}%;background:${aWins ? cA : cA+'88'}`}
                  ></div>
                  <div
                    class="ms-bar-b"
                    style={`width:${pctB}%;background:${bWins ? cB : cB+'88'}`}
                  ></div>
                </div>
              )}
            </div>

            <!-- Valor B -->
            <div class="ms-stat-val ms-stat-val--b">
              {row.type === 'cards' ? (
                <div class="ms-cards ms-cards--b">
                  {Array.from({ length: toNum(row.valueB) }, () => (
                    <span class={`ms-card ${row.label.includes('roja') ? 'ms-card--red' : 'ms-card--yellow'}`}></span>
                  ))}
                  {toNum(row.valueB) === 0 && <span class="ms-cards-zero">—</span>}
                </div>
              ) : (
                <span
                  class={`ms-val-text ${bWins && row.highlight ? 'ms-val--win' : ''}`}
                  style={bWins && row.highlight ? `color:${cB};text-shadow:0 0 12px ${cB}66` : ''}
                >
                  {row.valueB}
                </span>
              )}
            </div>

          </div>
        )
      })}
    </div>
  </div>

</div>

<style>
  /* ══ ROOT ══ */
  .ms-root {
    --cA: #00ff88;
    --cB: #f59e0b;
    --midnight: var(--color-theme-midnight, #0a0e1a);
    --gold:     var(--color-theme-gold, #c7a86b);
    --cream:    var(--color-theme-cream, #e8dcc8);
    --border:   rgba(199,168,107,.15);
    --surface:  rgba(255,255,255,.03);

    position: relative;
    width: 100%;
    max-width: 780px;
    margin: 0 auto;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
    isolation: isolate;
  }

  /* ══ FONDO ══ */
  .ms-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .ms-bg-glow-a {
    position: absolute; top: 0; left: -5%; width: 50%; height: 60%;
    filter: blur(60px);
    animation: glowPulse 6s ease-in-out infinite alternate;
  }
  .ms-bg-glow-b {
    position: absolute; top: 0; right: -5%; width: 50%; height: 60%;
    filter: blur(60px);
    animation: glowPulse 7s ease-in-out infinite alternate-reverse;
  }
  @keyframes glowPulse { 0%{opacity:.3} 100%{opacity:.85} }

  .ms-stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,.6), transparent),
      radial-gradient(1px 1px at 30% 55%, rgba(0,255,136,.4), transparent),
      radial-gradient(1px 1px at 55% 12%, rgba(168,85,247,.3), transparent),
      radial-gradient(1px 1px at 72% 78%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 88% 35%, rgba(0,255,136,.3), transparent),
      radial-gradient(1px 1px at 18% 82%, rgba(192,132,252,.3), transparent),
      radial-gradient(1px 1px at 62% 50%, rgba(255,255,255,.4), transparent);
    background-size: 220px 220px;
    opacity: .4;
  }
  .ms-scanlines {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      rgba(0,255,136,.008) 3px, rgba(0,255,136,.008) 4px
    );
  }

  /* Fondo base dark */
  .ms-root::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(160deg,
      color-mix(in srgb,var(--midnight) 88%,#00ff88) 0%,
      var(--midnight) 100%
    );
    z-index: -1;
  }

  /* ══ HEADER MARCADOR ══ */
  .ms-header {
    position: relative; z-index: 1;

    align-items: center;
    gap: 1rem;
    padding: 1.5rem 1.25rem 1rem;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(to bottom,
      rgba(0,255,136,.04) 0%,
      transparent 100%
    );
  }

  .ms-team {
    display: flex; align-items: center; gap: .6rem;
  }
  .ms-team--b { flex-direction: row-reverse; justify-content: flex-start; }

  .ms-team-logo {
    width: 40px; height: 40px; object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(255,255,255,.2));
    flex-shrink: 0;
  }
  .ms-team-name {
    font-size: clamp(.55rem, 2vw, .8rem);
    font-weight: 900; letter-spacing: .12em; text-transform: uppercase;
    line-height: 1.2; text-align: left;
  }
  .ms-team--b .ms-team-name { text-align: right; }

  /* Marcador */
  .ms-scoreboard {
    display: flex; flex-direction: column; align-items: center; gap: .4rem;
  }
  .ms-score-wrap {
    display: flex; align-items: center; gap: .75rem;
  }
  .ms-score {
    font-size: clamp(2.2rem, 8vw, 3.5rem);
    font-weight: 900; line-height: 1;
    min-width: clamp(1.8rem, 6vw, 2.8rem);
    text-align: center;
  }
  .ms-score-divider {
    display: flex; flex-direction: column; align-items: center; gap: .2rem;
  }
  .ms-live-dot-wrap {
    display: flex; align-items: center; gap: .3rem;
  }
  .ms-live-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 8px #ef4444;
    animation: liveBlink 1.1s ease-in-out infinite;
  }
  @keyframes liveBlink { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.3;transform:scale(.7)} }
  .ms-live-label {
    font-size: .42rem; font-weight: 700; letter-spacing: .2em;
    color: #ef4444;
  }
  .ms-score-sep {
    font-size: .9rem; color: rgba(232,220,200,.3); line-height: 1;
  }
  .ms-minute-badge {
    background: rgba(0,255,136,.1);
    border: 1px solid rgba(0,255,136,.3);
    border-radius: 99px; padding: .15rem .55rem;
  }
  .ms-minute-num {
    font-size: .62rem; font-weight: 700; letter-spacing: .05em; color: #00ff88;
  }

  /* Barra de tiempo */
  .ms-time-bar {
    position: relative;
    width: clamp(100px, 18vw, 160px);
    height: 3px;
    border-radius: 99px;
    background: rgba(255,255,255,.08);
    overflow: visible;
  }
  .ms-time-fill {
    height: 100%; border-radius: 99px;
    background: linear-gradient(to right, #00ff88, rgba(0,255,136,.5));
    transition: width .6s ease;
  }
  .ms-time-dot {
    position: absolute; top: 50%; transform: translate(-50%,-50%);
    width: 8px; height: 8px; border-radius: 50%;
    background: #00ff88; box-shadow: 0 0 8px #00ff88;
    transition: left .6s ease;
  }
  .ms-time-labels {
    display: flex; justify-content: space-between;
    font-size: .38rem; letter-spacing: .05em;
    color: rgba(232,220,200,.35);
    width: clamp(100px, 18vw, 160px);
    padding: 0 2px;
  }

  /* ══ TÍTULOS DE SECCIÓN ══ */
  .ms-events-title {
    display: flex; align-items: center; justify-content: center;
    gap: .6rem;
    font-size: .55rem; font-weight: 700; letter-spacing: .25em;
    color: rgba(0,255,136,.65);
    padding: .9rem 1.25rem .5rem;
    text-transform: uppercase;
  }
  .ms-section-diamond {
    display: inline-block; width: 5px; height: 5px;
    background: rgba(0,255,136,.6); transform: rotate(45deg);
  }

  /* ══ TIMELINE EVENTOS ══ */
  .ms-events-wrap {
    position: relative; z-index: 1;
    border-bottom: 1px solid var(--border);
    padding-bottom: .75rem;
  }

  .ms-events-timeline {
    display: flex; flex-direction: column; gap: .1rem;
    padding: .25rem 1.25rem .5rem;
    position: relative;
  }
  .ms-timeline-line {
    position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;
    background: linear-gradient(to bottom,
      transparent, rgba(0,255,136,.2) 20%, rgba(0,255,136,.15) 80%, transparent
    );
    pointer-events: none;
  }

  .ms-event {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: .4rem;
    padding: .35rem 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
    animation: eventIn .4s ease-out both;
  }
  .ms-event:last-child { border-bottom: none; }
  @keyframes eventIn {
    from { opacity:0; transform:translateY(6px); }
    to   { opacity:1; transform:translateY(0); }
  }

  .ms-event-side { display: flex; min-width: 0; }
  .ms-event-side--a { justify-content: flex-end; }
  .ms-event-side--b { justify-content: flex-start; }

  .ms-event-content {
    display: flex; flex-direction: column;
    max-width: 100%;
  }
  .ms-event-content--a { align-items: flex-end; }
  .ms-event-content--b { align-items: flex-start; }

  .ms-event-player {
    font-size: .6rem; font-weight: 700; letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--cream); white-space: nowrap;
  }
  .ms-event-sub {
    font-size: .48rem; letter-spacing: .04em;
    color: rgba(0,255,136,.7);
  }

  .ms-event-mid {
    display: flex; flex-direction: column; align-items: center;
    gap: .15rem; flex-shrink: 0;
  }
  .ms-event-min {
    font-size: .45rem; font-weight: 600; letter-spacing: .05em;
    color: rgba(232,220,200,.45);
  }
  .ms-event-icon {
    width: 26px; height: 26px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.08);
  }
  .ms-event-icon--goal   { background:rgba(0,255,136,.12); border-color:rgba(0,255,136,.35); }
  .ms-event-icon--yellow { background:rgba(234,179,8,.12);  border-color:rgba(234,179,8,.35); }
  .ms-event-icon--red    { background:rgba(239,68,68,.12);  border-color:rgba(239,68,68,.35); }
  .ms-event-icon--sub    { background:rgba(96,165,250,.12); border-color:rgba(96,165,250,.35); }
  .ms-event-icon--var    { background:rgba(168,85,247,.12); border-color:rgba(168,85,247,.35); }

  /* ══ ESTADÍSTICAS ══ */
  .ms-stats-wrap {
    position: relative; z-index: 1;
    padding-bottom: 1.25rem;
  }

  .ms-stats-list {
    display: flex; flex-direction: column;
    gap: 0;
    padding: 0 1.25rem;
  }

  .ms-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    gap: .5rem;
    padding: .6rem 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
  }
  .ms-stat-row:last-child { border-bottom: none; }

  .ms-stat-val {
    display: flex; align-items: center;
  }
  .ms-stat-val--a { justify-content: flex-start; }
  .ms-stat-val--b { justify-content: flex-end; }

  .ms-val-text {
    font-size: clamp(.7rem, 2vw, .9rem);
    font-weight: 700; letter-spacing: .04em;
    color: rgba(232,220,200,.75);
    transition: color .3s;
  }
  .ms-val--win { font-size: clamp(.75rem, 2.2vw, .95rem); }

  .ms-stat-center {
    display: flex; flex-direction: column; align-items: center; gap: .3rem;
  }

  .ms-stat-label {
    font-size: clamp(.42rem, 1.2vw, .58rem);
    font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(232,220,200,.5);
    text-align: center;
    white-space: nowrap;
  }

  /* Barra dual */
  .ms-bar {
    width: 100%;
    height: 5px;
    border-radius: 99px;
    display: flex;
    overflow: hidden;
    gap: 1px;
  }
  .ms-bar-a {
    height: 100%; border-radius: 99px 0 0 99px;
    transition: width .6s ease, background .3s;
  }
  .ms-bar-b {
    height: 100%; border-radius: 0 99px 99px 0;
    transition: width .6s ease, background .3s;
  }

  /* Tarjetas */
  .ms-cards {
    display: flex; gap: .25rem; align-items: center;
  }
  .ms-cards--b { justify-content: flex-end; }
  .ms-card {
    display: inline-block;
    width: 12px; height: 17px; border-radius: 2px;
  }
  .ms-card--yellow { background: #eab308; box-shadow: 0 0 6px rgba(234,179,8,.6); }
  .ms-card--red    { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,.6); }
  .ms-cards-zero {
    font-size: .65rem; color: rgba(232,220,200,.3);
  }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 480px) {
    .ms-header { padding: 1rem .75rem .75rem; gap: .5rem; }
    .ms-team-logo { width: 28px; height: 28px; }
    .ms-score { font-size: 2rem; }
    .ms-events-timeline { padding: .25rem .75rem .5rem; }
    .ms-stats-list { padding: 0 .75rem; }
    .ms-event-player { font-size: .52rem; }
    .ms-stat-label { white-space: normal; text-align: center; font-size: .4rem; }
  }
</style>