---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
<main class="login-root">

  <!-- Fondo espacial -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="login-stars"></div>
    <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[60%] h-[55%] rounded-full blur-[90px] opacity-20" style="background:radial-gradient(ellipse,#00ff88,transparent 70%)"></div>
    <div class="absolute top-0 left-0 w-[35%] h-[60%] rounded-full blur-[110px] opacity-15" style="background:radial-gradient(ellipse,#00ff88,transparent 70%)"></div>
    <div class="absolute top-0 right-0 w-[35%] h-[60%] rounded-full blur-[110px] opacity-12" style="background:radial-gradient(ellipse,#7c3aed,transparent 70%)"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px" style="background:linear-gradient(to right,transparent,rgba(0,255,136,.2),transparent)"></div>
    <!-- Arco de campo -->
    <div class="absolute bottom-[-6vw] left-1/2 -translate-x-1/2 w-[55vw] h-[14vw] rounded-[50%_50%_0_0/100%_100%_0_0] border border-[rgba(0,255,136,.07)]"></div>
  </div>

  <!-- Contenido centrado -->
  <div class="relative z-10 flex min-h-svh w-full items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">

      <!-- Logo / título -->
      <div class="mb-8 text-center">
        <div class="mb-3 flex justify-center gap-1.5">
          <span class="inline-block w-1.5 h-1.5 rotate-45 bg-[var(--color-theme-gold)] opacity-70"></span>
          <span class="inline-block w-1.5 h-1.5 rotate-45 bg-[var(--color-theme-gold)] opacity-70"></span>
          <span class="inline-block w-1.5 h-1.5 rotate-45 bg-[var(--color-theme-gold)] opacity-70"></span>
        </div>
        <h1 class="font-cinzel text-3xl font-black uppercase tracking-[0.12em] text-white md:text-4xl">
          BIENVENIDO
        </h1>
        <p class="mt-2 text-[0.6rem] font-semibold uppercase tracking-[0.25em] text-white/35">
          PLATAFORMA DEPORTIVA
        </p>
      </div>

      <!-- Card login -->
      <div class="login-card">
        <!-- Esquinas HUD -->
        <span class="hud-corner hud-corner--tl"></span>
        <span class="hud-corner hud-corner--tr"></span>
        <span class="hud-corner hud-corner--bl"></span>
        <span class="hud-corner hud-corner--br"></span>

        <!-- Glow interior -->
        <div class="absolute inset-0 rounded-2xl pointer-events-none" style="background:radial-gradient(ellipse at 50% 0%,rgba(0,255,136,.05),transparent 60%)"></div>

        <div class="relative z-10 p-7 md:p-8">

          <!-- PASO 1: Selección de rol -->
          <div id="step-role">
            <p class="mb-5 text-center font-cinzel text-[0.55rem] font-bold uppercase tracking-[0.22em] text-[rgba(0,255,136,.7)]">
              SELECCIONA TU ROL
            </p>

            <div class="grid grid-cols-2 gap-3">
              {[
                { id: 'administrativo', icon: '🏛️', label: 'Administrativo', desc: 'Crea y gestiona torneos' },
                { id: 'arbitro',        icon: '🟨',  label: 'Árbitro',        desc: 'Gestiona partidos'      },
                { id: 'tecnico',        icon: '📋',  label: 'Técnico',        desc: 'Diriges un equipo'      },
                { id: 'jugador',        icon: '⚽',  label: 'Jugador',        desc: 'Compites en torneos'    },
              ].map(role => (
                <button
                  class="role-btn"
                  data-role={role.id}
                  type="button"
                  aria-pressed="false"
                >
                  <span class="role-icon">{role.icon}</span>
                  <span class="role-label">{role.label}</span>
                  <span class="role-desc">{role.desc}</span>
                  <!-- check activo -->
                  <span class="role-check">✓</span>
                </button>
              ))}
            </div>

            <button
              id="btn-continue"
              type="button"
              disabled
              class="cta-primary mt-6 w-full opacity-40 cursor-not-allowed transition-opacity duration-200"
            >
              CONTINUAR
            </button>
          </div>

          <!-- PASO 2: Formulario login (oculto al inicio) -->
          <div id="step-form" class="hidden">

            <!-- Botón volver -->
            <button id="btn-back" type="button" class="mb-5 flex items-center gap-1.5 text-[0.55rem] font-bold uppercase tracking-[0.15em] text-white/40 hover:text-[#00ff88] transition-colors duration-200">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9 11.5L4.5 7 9 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Volver
            </button>

            <!-- Badge rol seleccionado -->
            <div class="mb-6 flex items-center justify-between rounded-xl border border-[rgba(0,255,136,.2)] bg-[rgba(0,255,136,.05)] px-4 py-2.5">
              <div class="flex items-center gap-2.5">
                <span id="form-role-icon" class="text-xl leading-none"></span>
                <div>
                  <p class="font-cinzel text-[0.6rem] font-black uppercase tracking-wider text-white" id="form-role-label"></p>
                  <p class="text-[0.5rem] text-white/35" id="form-role-desc"></p>
                </div>
              </div>
              <span class="text-[0.5rem] font-bold text-[#00ff88]">✓</span>
            </div>

            <!-- Formulario -->
            <form id="login-form" class="flex flex-col gap-4" novalidate>

              <div class="form-group">
                <label for="email" class="form-label">Correo electrónico</label>
                <div class="input-wrap">
                  <svg class="input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M1 5.5l7 4.5 7-4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="tucorreo@ejemplo.com"
                    class="form-input"
                    autocomplete="email"
                    required
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="password" class="form-label">Contraseña</label>
                <div class="input-wrap">
                  <svg class="input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="3" y="7" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M5 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    <circle cx="8" cy="11" r="1" fill="currentColor"/>
                  </svg>
                  <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="••••••••"
                    class="form-input"
                    autocomplete="current-password"
                    required
                  />
                  <button type="button" id="toggle-pw" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/70 transition-colors" aria-label="Mostrar contraseña">
                    <svg id="eye-open" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.2"/>
                      <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.2"/>
                    </svg>
                    <svg id="eye-closed" width="16" height="16" viewBox="0 0 16 16" fill="none" class="hidden">
                      <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.2"/>
                      <line x1="2" y1="2" x2="14" y2="14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                  </button>
                </div>
              </div>

              <!-- Recordar / olvidé -->
              <div class="flex items-center justify-between">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" class="form-check" id="remember" />
                  <span class="text-[0.55rem] font-medium text-white/40">Recordarme</span>
                </label>
                <a href="/auth/forgot" class="text-[0.55rem] font-bold tracking-wide text-[var(--color-theme-gold)]/70 hover:text-[var(--color-theme-gold)] transition-colors">
                  ¿Olvidaste tu contraseña?
                </a>
              </div>

              <!-- Error message -->
              <div id="login-error" class="hidden rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-2.5 text-[0.58rem] font-medium text-red-400">
                Correo o contraseña incorrectos. Intenta de nuevo.
              </div>

              <!-- Submit -->
              <button type="submit" class="cta-primary mt-1 w-full" id="btn-submit">
                <span id="btn-submit-text">INICIAR SESIÓN</span>
                <span id="btn-submit-loader" class="hidden login-loader"></span>
              </button>

            </form>

            <!-- Divider -->
            <div class="my-5 flex items-center gap-3">
              <div class="flex-1 h-px bg-white/[0.07]"></div>
              <span class="text-[0.5rem] font-medium uppercase tracking-[0.15em] text-white/25">o continúa con</span>
              <div class="flex-1 h-px bg-white/[0.07]"></div>
            </div>

            <!-- OAuth -->
            <div class="grid grid-cols-2 gap-3">
              <button type="button" class="oauth-btn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M15.32 6.55H8v3.1h4.18c-.18 1-.73 1.84-1.55 2.4v2h2.5c1.46-1.35 2.3-3.33 2.3-5.68 0-.55-.06-1.08-.1-1.82z" fill="#4285F4"/>
                  <path d="M8 16c2.16 0 3.97-.72 5.29-1.95l-2.5-2c-.72.48-1.64.76-2.79.76-2.14 0-3.95-1.45-4.6-3.4H.82v2.06A8 8 0 0 0 8 16z" fill="#34A853"/>
                  <path d="M3.4 9.41A4.8 4.8 0 0 1 3.14 8c0-.49.09-.97.26-1.41V4.53H.82A8 8 0 0 0 0 8c0 1.29.31 2.51.82 3.47l2.58-2.06z" fill="#FBBC05"/>
                  <path d="M8 3.18c1.2 0 2.28.41 3.13 1.22l2.34-2.34A8 8 0 0 0 8 0C4.87 0 2.2 1.79.82 4.53L3.4 6.59C4.05 4.63 5.86 3.18 8 3.18z" fill="#EA4335"/>
                </svg>
                Google
              </button>
              <button type="button" class="oauth-btn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                </svg>
                GitHub
              </button>
            </div>

            <!-- Registro -->
            <p class="mt-6 text-center text-[0.55rem] text-white/30">
              ¿No tienes cuenta?
              <a href="/auth/register" class="ml-1 font-bold text-[var(--color-theme-gold)]/80 hover:text-[var(--color-theme-gold)] transition-colors">
                Regístrate gratis
              </a>
            </p>

          </div>
          <!-- /step-form -->

        </div>
      </div>
      <!-- /login-card -->

      <!-- Footer -->
      <p class="mt-6 text-center text-[0.5rem] font-medium uppercase tracking-[0.15em] text-white/20">
        © 2025 Plataforma Deportiva · <a href="/privacidad" class="hover:text-white/40 transition-colors">Privacidad</a> · <a href="/terminos" class="hover:text-white/40 transition-colors">Términos</a>
      </p>

    </div>
  </div>
</main>
</Layout>

<script>
  // ─── Datos de roles ───
  const roles: Record<string, { icon: string; label: string; desc: string }> = {
    administrativo: { icon: '🏛️', label: 'Administrativo', desc: 'Crea y gestiona torneos' },
    arbitro:        { icon: '🟨',  label: 'Árbitro',        desc: 'Gestiona partidos'      },
    tecnico:        { icon: '📋',  label: 'Técnico',        desc: 'Diriges un equipo'      },
    jugador:        { icon: '⚽',  label: 'Jugador',        desc: 'Compites en torneos'    },
  }

  let selectedRole: string | null = null

  const stepRole   = document.getElementById('step-role')!
  const stepForm   = document.getElementById('step-form')!
  const btnCont    = document.getElementById('btn-continue') as HTMLButtonElement
  const btnBack    = document.getElementById('btn-back')!
  const roleBtns   = document.querySelectorAll<HTMLButtonElement>('.role-btn')

  const formRoleIcon  = document.getElementById('form-role-icon')!
  const formRoleLabel = document.getElementById('form-role-label')!
  const formRoleDesc  = document.getElementById('form-role-desc')!

  // Selección de rol
  roleBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      roleBtns.forEach(b => { b.dataset.active = 'false'; b.setAttribute('aria-pressed','false') })
      btn.dataset.active = 'true'
      btn.setAttribute('aria-pressed','true')
      selectedRole = btn.dataset.role ?? null
      btnCont.disabled = false
      btnCont.classList.remove('opacity-40','cursor-not-allowed')
    })
  })

  // Continuar → mostrar form
  btnCont.addEventListener('click', () => {
    if (!selectedRole) return
    const r = roles[selectedRole]
    formRoleIcon.textContent  = r.icon
    formRoleLabel.textContent = r.label
    formRoleDesc.textContent  = r.desc
    stepRole.classList.add('hidden')
    stepForm.classList.remove('hidden')
  })

  // Volver al paso de rol
  btnBack.addEventListener('click', () => {
    stepForm.classList.add('hidden')
    stepRole.classList.remove('hidden')
  })

  // Toggle contraseña
  const pwInput   = document.getElementById('password') as HTMLInputElement
  const togglePw  = document.getElementById('toggle-pw')!
  const eyeOpen   = document.getElementById('eye-open')!
  const eyeClosed = document.getElementById('eye-closed')!
  togglePw.addEventListener('click', () => {
    const show = pwInput.type === 'password'
    pwInput.type = show ? 'text' : 'password'
    eyeOpen.classList.toggle('hidden', show)
    eyeClosed.classList.toggle('hidden', !show)
  })

  // Submit simulado
  const form       = document.getElementById('login-form') as HTMLFormElement
  const btnSubmit  = document.getElementById('btn-submit') as HTMLButtonElement
  const btnText    = document.getElementById('btn-submit-text')!
  const btnLoader  = document.getElementById('btn-submit-loader')!
  const errMsg     = document.getElementById('login-error')!

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errMsg.classList.add('hidden')
    btnText.classList.add('hidden')
    btnLoader.classList.remove('hidden')
    btnSubmit.disabled = true

    // Simula llamada al backend
    await new Promise(r => setTimeout(r, 1800))

    // Demo: si email contiene "error", muestra error
    const email = (document.getElementById('email') as HTMLInputElement).value
    if (email.includes('error')) {
      errMsg.classList.remove('hidden')
      btnText.classList.remove('hidden')
      btnLoader.classList.add('hidden')
      btnSubmit.disabled = false
      return
    }

    // Redirige según rol
    const redirects: Record<string, string> = {
      administrativo: '/dashboard/admin',
      arbitro:        '/dashboard/arbitro',
      tecnico:        '/dashboard/tecnico',
      jugador:        '/dashboard/jugador',
    }
    window.location.href = redirects[selectedRole ?? 'jugador'] ?? '/dashboard'
  })
</script>

<style>
  /* ─── Root ─── */
  .login-root {
    position: relative;
    min-height: 100svh;
    background: radial-gradient(ellipse at 50% -10%, #0b2a1a 0%, #050d08 55%, #03080e 100%);
    overflow: hidden;
  }

  /* Estrellas */
  .login-stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 8%  14%, #fff, transparent),
      radial-gradient(1px   1px   at 24% 60%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 51% 11%, #a855f7, transparent),
      radial-gradient(1px   1px   at 70% 78%, #fff, transparent),
      radial-gradient(2px   2px   at 87% 37%, #00ff88, transparent),
      radial-gradient(1px   1px   at 16% 84%, #c084fc, transparent),
      radial-gradient(1.5px 1.5px at 61% 49%, #fff, transparent),
      radial-gradient(1px   1px   at 43% 31%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 93%  7%, #fff, transparent);
    background-size: 280px 280px;
    opacity: .45;
    animation: twinkle 7s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0%{opacity:.2} 100%{opacity:.65} }

  /* ─── Card ─── */
  .login-card {
    position: relative;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 20%, transparent);
    background: linear-gradient(160deg,
      color-mix(in srgb, var(--color-theme-midnight, #0a0e1a) 90%, #00ff88) 0%,
      var(--color-theme-midnight, #0a0e1a) 100%
    );
    backdrop-filter: blur(12px);
    overflow: hidden;
    animation: cardIn .5s cubic-bezier(.22,1,.36,1) both;
  }
  @keyframes cardIn {
    from { opacity:0; transform:translateY(20px) scale(.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }

  /* Esquinas HUD */
  .hud-corner {
    position: absolute;
    width: 12px; height: 12px; border-style: solid;
    border-color: color-mix(in srgb, var(--color-theme-gold) 30%, transparent);
    pointer-events: none; z-index: 2;
  }
  .hud-corner--tl { top:8px;left:8px;border-width:1.5px 0 0 1.5px }
  .hud-corner--tr { top:8px;right:8px;border-width:1.5px 1.5px 0 0 }
  .hud-corner--bl { bottom:8px;left:8px;border-width:0 0 1.5px 1.5px }
  .hud-corner--br { bottom:8px;right:8px;border-width:0 1.5px 1.5px 0 }

  /* ─── Botones de rol ─── */
  .role-btn {
    position: relative;
    display: flex; flex-direction: column; align-items: center;
    gap: .35rem; padding: 1rem .75rem;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    background: rgba(255,255,255,.02);
    cursor: pointer;
    transition: border-color .2s, background .2s, transform .2s, box-shadow .2s;
    text-align: center;
    overflow: hidden;
  }
  .role-btn:hover {
    border-color: color-mix(in srgb, var(--color-theme-gold) 40%, transparent);
    background: rgba(255,255,255,.04);
    transform: translateY(-2px);
  }
  .role-btn[data-active="true"] {
    border-color: #00ff88;
    background: rgba(0,255,136,.07);
    box-shadow: 0 0 0 1px #00ff88, 0 0 20px rgba(0,255,136,.12);
    transform: translateY(-2px);
  }

  .role-icon   { font-size: 1.6rem; line-height: 1; }
  .role-label  {
    font-family: var(--font-cinzel,'Cinzel'),serif;
    font-size: .6rem; font-weight: 800;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--color-theme-cream, #e8dcc8);
    transition: color .2s;
  }
  .role-btn[data-active="true"] .role-label { color: #00ff88; }
  .role-desc   { font-size: .48rem; color: rgba(255,255,255,.35); line-height: 1.3; }

  .role-check {
    position: absolute; top: 6px; right: 8px;
    font-size: .55rem; font-weight: 800; color: #00ff88;
    opacity: 0; transition: opacity .2s;
  }
  .role-btn[data-active="true"] .role-check { opacity: 1; }

  /* ─── Inputs ─── */
  .form-group { display: flex; flex-direction: column; gap: .4rem; }
  .form-label {
    font-family: var(--font-cinzel,'Cinzel'),serif;
    font-size: .52rem; font-weight: 700;
    letter-spacing: .12em; text-transform: uppercase;
    color: rgba(255,255,255,.45);
  }
  .input-wrap { position: relative; display: flex; align-items: center; }
  .input-icon {
    position: absolute; left: .85rem; color: rgba(255,255,255,.25);
    pointer-events: none; flex-shrink: 0;
  }
  .form-input {
    width: 100%;
    padding: .7rem .85rem .7rem 2.5rem;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    background: rgba(255,255,255,.03);
    color: var(--color-theme-cream, #e8dcc8);
    font-family: var(--font-cinzel,'Cinzel'),serif;
    font-size: .7rem; letter-spacing: .04em;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
    caret-color: #00ff88;
  }
  .form-input::placeholder { color: rgba(255,255,255,.2); font-size: .65rem; }
  .form-input:focus {
    border-color: rgba(0,255,136,.45);
    background: rgba(0,255,136,.03);
    box-shadow: 0 0 0 3px rgba(0,255,136,.07);
  }

  /* Checkbox custom */
  .form-check {
    appearance: none; -webkit-appearance: none;
    width: 14px; height: 14px; border-radius: 4px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 30%, transparent);
    background: transparent; cursor: pointer;
    position: relative; transition: border-color .2s, background .2s;
    flex-shrink: 0;
  }
  .form-check:checked {
    background: #00ff88; border-color: #00ff88;
  }
  .form-check:checked::after {
    content: '✓'; position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .55rem; font-weight: 900; color: #000;
  }

  /* ─── CTA ─── */
  .cta-primary {
    display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
    padding: .75rem 1.5rem;
    border-radius: 10px;
    font-family: var(--font-cinzel,'Cinzel'),serif;
    font-size: .62rem; font-weight: 800; letter-spacing: .18em;
    text-transform: uppercase; text-decoration: none;
    background: var(--color-theme-gold, #c7a86b);
    color: var(--color-theme-midnight, #0a1024);
    border: none; cursor: pointer;
    transition: transform .2s, filter .2s, box-shadow .2s, opacity .2s;
  }
  .cta-primary:not(:disabled):hover {
    transform: translateY(-1px);
