---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
<div class="login-root">


  <!-- ══ CONTENIDO ══ -->
  <div class="relative z-10 flex min-h-svh w-full items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">

      <!-- Logo / nombre app -->
      <div class="mb-10 text-center">
        <div class="login-diamonds mb-3">
          <span></span><span></span><span></span>
        </div>
        <h1 class="font-cinzel text-3xl font-black uppercase tracking-[0.12em] text-white">
          COPA <span class="login-green-text">CHONTADURO</span>
        </h1>
        <p class="mt-1.5 text-[0.58rem] font-semibold uppercase tracking-[0.3em] text-white/35">
          PLATAFORMA DEPORTIVA
        </p>
      </div>

      <!-- Tarjeta principal -->
      <div class="login-card">

        <!-- Esquinas HUD -->
        <span class="hud-corner hud-corner--tl" id="hud-tl"></span>
        <span class="hud-corner hud-corner--tr" id="hud-tr"></span>
        <span class="hud-corner hud-corner--bl" id="hud-bl"></span>
        <span class="hud-corner hud-corner--br" id="hud-br"></span>

        <!-- Glow interno -->
        <div class="login-card-glow" aria-hidden="true"></div>

        <!-- Cabecera -->
        <div class="mb-7 text-center">
          <p class="font-cinzel text-[0.6rem] font-bold uppercase tracking-[0.25em] text-[#00ff88]/70">
            BIENVENIDO DE VUELTA
          </p>
          <h2 class="mt-1 font-cinzel text-xl font-black uppercase tracking-wide text-white">
            INICIAR SESIÓN
          </h2>
        </div>

        <!-- ── SELECCIÓN DE ROL ── -->
        <div class="mb-6">
          <p class="mb-3 text-[0.55rem] font-bold uppercase tracking-[0.2em] text-white/40">
            Selecciona tu rol
          </p>
          <div class="grid grid-cols-2 gap-2.5" id="role-grid">

            {[
              { id: 'jugador',        label: 'Jugador',        icon: '⚽', desc: 'Compite en torneos',        color: '#00ff88' },
              { id: 'tecnico',        label: 'Técnico',        icon: '📋', desc: 'Gestiona tu equipo',        color: '#38bdf8' },
              { id: 'arbitro',        label: 'Árbitro',        icon: '🟨', desc: 'Dirige los partidos',       color: '#fbbf24' },
              { id: 'administrativo', label: 'Administrador',  icon: '🏆', desc: 'Crea y gestiona torneos',   color: '#a78bfa' },
            ].map(role => (
              <button
                type="button"
                class="role-btn"
                data-role={role.id}
                data-color={role.color}
                aria-pressed="false"
              >
                <span class="role-icon" style={`background:${role.color}14;border-color:${role.color}30`}>{role.icon}</span>
                <span class="role-label">{role.label}</span>
                <span class="role-desc">{role.desc}</span>
                <span class="role-check" style={`background:${role.color};box-shadow:0 0 8px ${role.color}88`}>✓</span>
              </button>
            ))}

          </div>
        </div>

        <!-- ── FORMULARIO ── -->
        <form class="space-y-4" id="login-form" novalidate>

          <!-- Email -->
          <div class="login-field-wrap">
            <label class="login-label" for="email">Correo electrónico</label>
            <div class="login-input-wrap">
              <span class="login-input-icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <rect x="1" y="3" width="12" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M1 4.5l6 4 6-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </span>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="tu@correo.com"
                autocomplete="email"
                class="login-input"
                required
              />
            </div>
          </div>

          <!-- Contraseña -->
          <div class="login-field-wrap">
            <div class="flex items-center justify-between mb-1.5">
              <label class="login-label !mb-0" for="password">Contraseña</label>
              <a href="/recuperar" class="text-[0.52rem] font-semibold uppercase tracking-wide text-[#00ff88]/60 hover:text-[#00ff88] transition-colors">
                ¿Olvidaste?
              </a>
            </div>
            <div class="login-input-wrap">
              <span class="login-input-icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <rect x="3" y="6" width="8" height="6.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M4.5 6V4.5a2.5 2.5 0 015 0V6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </span>
              <input
                id="password"
                name="password"
                type="password"
                placeholder="••••••••"
                autocomplete="current-password"
                class="login-input"
                required
              />
              <button type="button" id="toggle-password" class="login-eye" tabindex="-1" aria-label="Mostrar contraseña">
                <svg id="eye-open" width="15" height="15" viewBox="0 0 15 15" fill="none">
                  <path d="M1 7.5S3.5 3 7.5 3s6.5 4.5 6.5 4.5S11.5 12 7.5 12 1 7.5 1 7.5z" stroke="currentColor" stroke-width="1.2"/>
                  <circle cx="7.5" cy="7.5" r="2" stroke="currentColor" stroke-width="1.2"/>
                </svg>
                <svg id="eye-closed" class="hidden" width="15" height="15" viewBox="0 0 15 15" fill="none">
                  <path d="M1 7.5S3.5 3 7.5 3s6.5 4.5 6.5 4.5S11.5 12 7.5 12 1 7.5 1 7.5z" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M2 2l11 11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Error message -->
          <div id="login-error" class="hidden rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-2">
            <p class="text-[0.58rem] font-semibold text-red-400" id="login-error-text">
              Por favor selecciona un rol antes de continuar.
            </p>
          </div>

          <!-- Submit -->
          <button type="submit" class="login-submit" id="login-btn">
            <span id="btn-text">INGRESAR</span>
            <span id="btn-loader" class="hidden">
              <svg class="login-spinner" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" stroke-dasharray="20 18"/>
              </svg>
              INGRESANDO...
            </span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" id="btn-arrow">
              <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

        </form>

        <!-- Separador -->
        <div class="my-6 flex items-center gap-3">
          <div class="flex-1 h-px" style="background:linear-gradient(to right,transparent,rgba(255,255,255,.08))"></div>
          <span class="text-[0.52rem] uppercase tracking-[0.2em] text-white/25">o continúa con</span>
          <div class="flex-1 h-px" style="background:linear-gradient(to left,transparent,rgba(255,255,255,.08))"></div>
        </div>

        <!-- Social login -->
        <div class="grid grid-cols-2 gap-3">
          {[
            { label: 'Google',   icon: 'G', color: '#ea4335' },
            { label: 'Discord',  icon: 'D', color: '#5865f2' },
          ].map(s => (
            <button type="button" class="social-btn">
              <span class="social-icon" style={`color:${s.color}`}>{s.icon}</span>
              <span>{s.label}</span>
            </button>
          ))}
        </div>

        <!-- Registro -->
        <p class="mt-7 text-center text-[0.58rem] text-white/30">
          ¿No tienes cuenta?{' '}
          <a href="/registro" class="font-bold text-[#00ff88]/70 hover:text-[#00ff88] transition-colors underline underline-offset-2">
            Regístrate gratis
          </a>
        </p>

      </div>
      <!-- /login-card -->

    </div>
  </div>

</div>
</Layout>

<script>
  // ── Selección de rol ──
  const roleBtns = document.querySelectorAll<HTMLButtonElement>('.role-btn')
  let selectedRole = ''

  roleBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      selectedRole = btn.dataset.role ?? ''
      const color  = btn.dataset.color ?? '#00ff88'

      roleBtns.forEach(b => {
        b.setAttribute('aria-pressed', 'false')
        b.classList.remove('role-btn--active')
      })
      btn.setAttribute('aria-pressed', 'true')
      btn.classList.add('role-btn--active')

      // Cambiar color de acento de la card y esquinas HUD
      document.documentElement.style.setProperty('--login-accent', color)
      ;['hud-tl','hud-tr','hud-bl','hud-br'].forEach(id => {
        const el = document.getElementById(id)
        if (el) el.style.borderColor = color + '80'
      })
      document.querySelector<HTMLElement>('.login-card-glow')!.style.background =
        `radial-gradient(ellipse at 50% 0%,${color}0f 0%,transparent 60%)`

      // Ocultar error si lo había
      document.getElementById('login-error')!.classList.add('hidden')
    })
  })

  // ── Toggle contraseña ──
  document.getElementById('toggle-password')?.addEventListener('click', () => {
    const input = document.getElementById('password') as HTMLInputElement
    const isText = input.type === 'text'
    input.type = isText ? 'password' : 'text'
    document.getElementById('eye-open')!.classList.toggle('hidden', !isText)
    document.getElementById('eye-closed')!.classList.toggle('hidden', isText)
  })

  // ── Submit ──
  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const errorEl   = document.getElementById('login-error')!
    const errorText = document.getElementById('login-error-text')!
    const btnText   = document.getElementById('btn-text')!
    const btnLoader = document.getElementById('btn-loader')!
    const btnArrow  = document.getElementById('btn-arrow')!
    const btn       = document.getElementById('login-btn') as HTMLButtonElement

    // Validar rol
    if (!selectedRole) {
      errorText.textContent = 'Por favor selecciona un rol antes de continuar.'
      errorEl.classList.remove('hidden')
      document.getElementById('role-grid')?.scrollIntoView({ behavior:'smooth', block:'nearest' })
      return
    }

    // Loading state
    btnText.classList.add('hidden')
    btnArrow.classList.add('hidden')
    btnLoader.classList.remove('hidden')
    btn.disabled = true

    // Simular petición (reemplaza con tu lógica real)
    await new Promise(r => setTimeout(r, 1400))

    // Redirigir según rol
    const routes: Record<string, string> = {
      jugador:        '/dashboard/jugador',
      tecnico:        '/dashboard/tecnico',
      arbitro:        '/dashboard/arbitro',
      administrativo: '/dashboard/admin',
    }
    window.location.href = routes[selectedRole] ?? '/dashboard'
  })
</script>

<style>
  /* ── Root ── */
  .login-root {
    position: relative;
    width: 100%;
    min-height: 100svh;
    background: radial-gradient(ellipse at 50% -5%, #0b2a1a 0%, #050d08 55%, #03080e 100%);
    isolation: isolate;
    font-family: var(--font-cinzel, 'Cinzel'), serif;
  }

  /* ── Estrellas ── */
  .login-stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 8%  15%, #fff, transparent),
      radial-gradient(1px   1px   at 25% 60%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 52% 10%, #a855f7, transparent),
      radial-gradient(1px   1px   at 72% 78%, #fff, transparent),
      radial-gradient(2px   2px   at 88% 38%, #00ff88, transparent),
      radial-gradient(1px   1px   at 16% 85%, #c084fc, transparent),
      radial-gradient(1.5px 1.5px at 62% 50%, #fff, transparent),
      radial-gradient(1px   1px   at 44% 30%, #aaffcc, transparent),
      radial-gradient(2px   2px   at 93%  8%, #fff, transparent);
    background-size: 280px 280px;
    opacity: .45;
    animation: twinkle 7s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0%{opacity:.2} 100%{opacity:.65} }

  .login-scanlines {
    background: repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      rgba(0,255,136,.008) 3px, rgba(0,255,136,.008) 4px
    );
  }

  /* ── Texto verde gradiente ── */
  .login-green-text {
    background: linear-gradient(to right, #00ff88, #34d399);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    filter: drop-shadow(0 0 16px rgba(0,255,136,.5));
  }

  /* ── Diamantes header ── */
  .login-diamonds { display: flex; justify-content: center; gap: 6px; }
  .login-diamonds span {
    display: inline-block; width: 6px; height: 6px;
    background: var(--color-theme-gold, #c7a86b);
    transform: rotate(45deg); opacity: .7;
    box-shadow: 0 0 8px var(--color-theme-gold, #c7a86b);
    animation: sparkle 3s ease-in-out infinite alternate;
  }
  .login-diamonds span:nth-child(2) { animation-delay: .5s; }
  .login-diamonds span:nth-child(3) { animation-delay: 1s; }
  @keyframes sparkle {
    0%  { opacity:.3; transform:rotate(45deg) scale(.8); }
    100%{ opacity:1;  transform:rotate(45deg) scale(1.3); }
  }

  /* ── Tarjeta login ── */
  .login-card {
    position: relative;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,.08);
    background: linear-gradient(160deg,
      color-mix(in srgb,var(--color-theme-midnight,#0a0e1a) 88%,#00ff88) 0%,
      var(--color-theme-midnight,#0a0e1a) 100%
    );
    backdrop-filter: blur(16px);
    padding: 2rem 1.75rem;
    overflow: hidden;
    animation: cardIn .6s cubic-bezier(.22,1,.36,1) both;
  }
  @keyframes cardIn {
    from { opacity:0; transform:translateY(24px) scale(.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }

  .login-card-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at 50% 0%, rgba(0,255,136,.06) 0%, transparent 60%);
    transition: background .4s;
  }

  /* ── Esquinas HUD ── */
  .hud-corner {
    position: absolute; width: 14px; height: 14px;
    border-style: solid;
    border-color: rgba(0,255,136,.3);
    pointer-events: none;
    transition: border-color .3s, width .3s, height .3s;
  }
  .hud-corner--tl { top: 8px; left: 8px;   border-width: 1.5px 0 0 1.5px; }
  .hud-corner--tr { top: 8px; right: 8px;  border-width: 1.5px 1.5px 0 0; }
  .hud-corner--bl { bottom: 8px; left: 8px;  border-width: 0 0 1.5px 1.5px; }
  .hud-corner--br { bottom: 8px; right: 8px; border-width: 0 1.5px 1.5px 0; }

  /* ── Botones de rol ── */
  .role-btn {
    position: relative;
    display: flex; flex-direction: column; align-items: flex-start; gap: .25rem;
    padding: .75rem .8rem;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.025);
    cursor: pointer; text-align: left;
    transition: border-color .2s, background .2s, transform .15s;
    overflow: hidden;
  }
  .role-btn:hover {
    border-color: rgba(255,255,255,.18);
    background: rgba(255,255,255,.045);
    transform: translateY(-1px);
  }
  .role-btn--active {
    border-color: var(--login-accent, #00ff88) !important;
    background: color-mix(in srgb, var(--login-accent,#00ff88) 8%, transparent) !important;
    box-shadow: 0 0 18px color-mix(in srgb,var(--login-accent,#00ff88) 20%,transparent);
  }

  .role-icon {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 8px; border: 1px solid;
    font-size: 1rem; margin-bottom: .1rem;
  }
  .role-label {
    font-family: var(--font-cinzel,'Cinzel'), serif;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .06em; text-transform: uppercase;
    color: rgba(232,220,200,.9);
  }
  .role-desc {
    font-size: .48rem; letter-spacing: .04em;
    color: rgba(232,220,200,.4); text-transform: none;
    font-family: sans-serif;
  }
  /* Check de rol seleccionado */
  .role-check {
    position: absolute; top: 7px; right: 7px;
    display: none; align-items: center; justify-content: center;
    width: 18px; height: 18px; border-radius: 50%;
    font-size: .55rem; font-weight: 900; color: #000;
  }
  .role-btn--active .role-check { display: flex; }

  /* ── Campos ── */
  .login-label {
    display: block; margin-bottom: 1.5;
    font-size: .52rem; font-weight: 700; letter-spacing: .15em;
    text-transform: uppercase; color: rgba(232,220,200,.5);
    margin-bottom: 6px;
  }

  .login-input-wrap {
    position: relative; display: flex; align-items: center;
  }
  .login-input-icon {
    position: absolute; left: 12px;
    color: rgba(232,220,200,.3);
    display: flex; align-items: center; pointer-events: none;
  }
  .login-input {
    width: 100%; padding: .7rem .7rem .7rem 2.4rem;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,.09);
    background: rgba(255,255,255,.04);
    color: rgba(232,220,200,.9);
    font-family: var(--font-cinzel,'Cinzel'), serif;
    font-size: .7rem; letter-spacing: .04em;
    outline: none;
    transition: border-color .2s, background .2s, box-shadow .2s;
  }
  .login-input::placeholder { color: rgba(232,220,200,.2); }
  .login-input:focus {
    border-color: rgba(0,255,136,.4);
    background: rgba(0,255,136,.04);
    box-shadow: 0 0 0 3px rgba(0,255,136,.06);
  }

  .login-eye {
    position: absolute; right: 10px;
    color: rgba(232,220,200,.3); padding: 4px;
    display: flex; align-items: center; cursor: pointer;
    background: none; border: none;
    transition: color .2s;
  }
  .login-eye:hover { color: rgba(232,220,200,.7); }

  /* ── Submit ── */
  .login-submit {
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    width: 100%; padding: .8rem 1rem;
    border-radius: 10px; border: none; cursor: pointer;
    font-family: var(--font-cinzel,'Cinzel'), serif;
    font-size: .65rem; font-weight: 800; letter-spacing: .2em;
    text-transform: uppercase;
    background: var(--color-theme-gold, #c7a86b);
    color: var(--color-theme-midnight, #0a0e1a);
    transition: transform .2s, filter .2s, box-shadow .2s, opacity .2s;
    box-shadow: 0 0 20px rgba(199,168,107,.2);
  }
  .login-submit:hover:not(:disabled) {
    transform: translateY(-1px);
    filter: brightness(1.1);
    box-shadow: 0 0 32px rgba(199,168,107,.35);
  }
  .login-submit:disabled { opacity: .7; cursor: not-allowed; }

  /* Spinner animación */
  .login-spinner { animation: spin .8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Social buttons ── */
  .social-btn {
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    padding: .6rem .75rem; border-radius: 10px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.025); cursor: pointer;
    font-family: var(--font-cinzel,'Cinzel'), serif;
    font-size: .55rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: rgba(232,220,200,.55);
    transition: border-color .2s, background .2s, color .2s;
  }
  .social-btn:hover {
    border-color: rgba(255,255,255,.2);
    background: rgba(255,255,255,.05);
    color: rgba(232,220,200,.9);
  }
  .social-icon { font-size: .95rem; font-weight: 900; }
</style>